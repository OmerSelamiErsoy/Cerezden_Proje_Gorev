@{
    Layout = "_AdminLayout";
}
<div id="parametre-app">
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item"><a class="nav-link" :class="{ active: tab === 'durum' }" href="#" @@click.prevent="tab='durum'">Durumlar</a></li>
        <li class="nav-item"><a class="nav-link" :class="{ active: tab === 'kategori' }" href="#" @@click.prevent="tab='kategori'">Kategoriler</a></li>
    </ul>
    <div v-show="tab === 'durum'">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">Proje / Adım Durumları<button class="btn btn-primary btn-sm" @@click="durumEkle()"><i class="fas fa-plus"></i> Ekle</button></div>
            <table class="table mb-0"><thead><tr><th>Ad</th><th>Sira</th><th></th></tr></thead><tbody>
                <tr v-for="d in durumlar" :key="d.id"><td>{{ d.ad }}</td><td>{{ d.sira }}</td><td><button class="btn btn-sm btn-outline-secondary" @@click="durumDuzenle(d)">Düzenle</button> <button class="btn btn-sm btn-outline-danger" @@click="durumSil(d.id)">Sil</button></td></tr>
            </tbody></table>
        </div>
    </div>
    <div v-show="tab === 'kategori'">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">Proje Detay Kategorileri<button class="btn btn-primary btn-sm" @@click="kategoriEkle()"><i class="fas fa-plus"></i> Ekle</button></div>
            <table class="table mb-0"><thead><tr><th>Ad</th><th>Sira</th><th></th></tr></thead><tbody>
                <tr v-for="k in kategoriler" :key="k.id"><td>{{ k.ad }}</td><td>{{ k.sira }}</td><td><button class="btn btn-sm btn-outline-secondary" @@click="kategoriDuzenle(k)">Düzenle</button> <button class="btn btn-sm btn-outline-danger" @@click="kategoriSil(k.id)">Sil</button></td></tr>
            </tbody></table>
        </div>
    </div>
    <div class="modal fade" id="durumModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">{{ durumForm.id ? 'Düzenle' : 'Yeni Durum' }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div class="mb-3">
                <label class="form-label">Ad</label>
                <input v-model="durumForm.ad" class="form-control" />
            </div>
            <div>
                <label class="form-label">Sıra</label>
                <input v-model.number="durumForm.sira" type="number" class="form-control" />
            </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button><button type="button" class="btn btn-primary" @@click="durumKaydet">Kaydet</button></div>
    </div></div></div>
    <div class="modal fade" id="kategoriModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">{{ kategoriForm.id ? 'Düzenle' : 'Yeni Kategori' }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div class="mb-3">
                <label class="form-label">Ad</label>
                <input v-model="kategoriForm.ad" class="form-control" />
            </div>
            <div>
                <label class="form-label">Sıra</label>
                <input v-model.number="kategoriForm.sira" type="number" class="form-control" />
            </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button><button type="button" class="btn btn-primary" @@click="kategoriKaydet">Kaydet</button></div>
    </div></div></div>
</div>
@section Scripts {
<script>
const { createApp } = Vue;
createApp({
    data() {
        return {
            tab: 'durum',
            durumlar: [],
            kategoriler: [],
            durumForm: { id: null, ad: '', sira: 0 },
            kategoriForm: { id: null, ad: '', sira: 0 }
        };
    },
    mounted() {
        this.durumYukle();
        this.kategoriYukle();
    },
    methods: {
        durumYukle() { axios.get('/api/Parametre/durumlar').then(r => { this.durumlar = r.data; }); },
        kategoriYukle() { axios.get('/api/Parametre/kategoriler').then(r => { this.kategoriler = r.data; }); },
        durumEkle() { this.durumForm = { id: null, ad: '', sira: this.durumlar.length + 1 }; new bootstrap.Modal(document.getElementById('durumModal')).show(); },
        durumDuzenle(d) { this.durumForm = { id: d.id, ad: d.ad, sira: d.sira }; new bootstrap.Modal(document.getElementById('durumModal')).show(); },
        durumKaydet() {
            var payload = { ad: this.durumForm.ad || '', sira: this.durumForm.sira || 0 };
            if (this.durumForm.id) {
                axios.put('/api/Parametre/durumlar/' + this.durumForm.id, payload).then(() => { this.durumYukle(); bootstrap.Modal.getInstance(document.getElementById('durumModal')).hide(); }).catch(err => { alert(err.response?.data?.message || 'Kayıt güncellenemedi.'); });
            } else {
                axios.post('/api/Parametre/durumlar', payload).then(() => { this.durumYukle(); bootstrap.Modal.getInstance(document.getElementById('durumModal')).hide(); }).catch(err => { alert(err.response?.data?.message || 'Kayıt eklenemedi.'); });
            }
        },
        durumSil(id) { if (confirm('Silinsin mi?')) axios.delete('/api/Parametre/durumlar/' + id).then(() => this.durumYukle()); },
        kategoriEkle() { this.kategoriForm = { id: null, ad: '', sira: this.kategoriler.length + 1 }; new bootstrap.Modal(document.getElementById('kategoriModal')).show(); },
        kategoriDuzenle(k) { this.kategoriForm = { id: k.id, ad: k.ad, sira: k.sira }; new bootstrap.Modal(document.getElementById('kategoriModal')).show(); },
        kategoriKaydet() {
            var payload = { ad: this.kategoriForm.ad || '', sira: this.kategoriForm.sira || 0 };
            if (this.kategoriForm.id) {
                axios.put('/api/Parametre/kategoriler/' + this.kategoriForm.id, payload).then(() => { this.kategoriYukle(); bootstrap.Modal.getInstance(document.getElementById('kategoriModal')).hide(); }).catch(err => { alert(err.response?.data?.message || 'Kayıt güncellenemedi.'); });
            } else {
                axios.post('/api/Parametre/kategoriler', payload).then(() => { this.kategoriYukle(); bootstrap.Modal.getInstance(document.getElementById('kategoriModal')).hide(); }).catch(err => { alert(err.response?.data?.message || 'Kayıt eklenemedi.'); });
            }
        },
        kategoriSil(id) { if (confirm('Silinsin mi?')) axios.delete('/api/Parametre/kategoriler/' + id).then(() => this.kategoriYukle()); }
    }
}).mount('#parametre-app');
</script>
}
