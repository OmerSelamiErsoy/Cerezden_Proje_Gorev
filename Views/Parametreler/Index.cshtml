@{
    Layout = "_AdminLayout";
    var genelYetkiliMi = ViewBag.GenelYetkiliMi == true;
}
<div id="parametre-app" data-vue-page data-genel-yetkili="@(genelYetkiliMi ? "true" : "false")" v-cloak>
    <div class="v-cloak-loading d-flex align-items-center justify-content-center py-5">
        <div class="w-100 text-center">
            <div class="small text-muted mb-2">Yükleniyor...</div>
            <div class="progress" style="max-width:260px;margin:0 auto;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:100%"></div>
            </div>
        </div>
    </div>
    <div class="v-cloak-hidden">
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item" v-if="genelYetkiliMi"><a class="nav-link" :class="{ active: tab === 'durum' }" href="#" @@click.prevent="tab='durum'">Durumlar</a></li>
        <li class="nav-item"><a class="nav-link" :class="{ active: tab === 'kategori' }" href="#" @@click.prevent="tab='kategori'">Kategoriler</a></li>
        <li class="nav-item" v-if="genelYetkiliMi"><a class="nav-link" :class="{ active: tab === 'adetBirimi' }" href="#" @@click.prevent="tab='adetBirimi'">Adet Birimleri</a></li>
        <li class="nav-item" v-if="genelYetkiliMi"><a class="nav-link" :class="{ active: tab === 'sahaDenetimKategori' }" href="#" @@click.prevent="tab='sahaDenetimKategori'">Saha Denetim Kategorileri</a></li>
    </ul>
    <div v-show="genelYetkiliMi && tab === 'durum'">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">Proje / Adım Durumları<button class="btn btn-primary btn-sm" @@click="durumEkle()"><i class="fas fa-plus"></i> Ekle</button></div>
            <table class="table mb-0"><thead><tr><th>Ad</th><th>Sira</th><th></th></tr></thead><tbody>
                <tr v-for="d in durumlar" :key="d.id"><td>{{ d.ad }}</td><td>{{ d.sira }}</td><td><button class="btn btn-sm btn-outline-secondary" @@click="durumDuzenle(d)"><i class="fas fa-edit me-1"></i> Düzenle</button> <button class="btn btn-sm btn-outline-danger" @@click="durumSil(d.id)"><i class="fas fa-trash me-1"></i> Sil</button></td></tr>
            </tbody></table>
        </div>
    </div>
    <div v-show="tab === 'kategori'">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">Proje Detay Kategorileri<button class="btn btn-primary btn-sm" @@click="kategoriEkle()"><i class="fas fa-plus"></i> Ekle</button></div>
            <table class="table mb-0"><thead><tr><th>Ad</th><th>Sira</th><th></th></tr></thead><tbody>
                <tr v-for="k in kategoriler" :key="k.id"><td>{{ k.ad }}</td><td>{{ k.sira }}</td><td><button class="btn btn-sm btn-outline-secondary" @@click="kategoriDuzenle(k)"><i class="fas fa-edit me-1"></i> Düzenle</button> <button class="btn btn-sm btn-outline-danger" @@click="kategoriSil(k.id)"><i class="fas fa-trash me-1"></i> Sil</button></td></tr>
            </tbody></table>
        </div>
    </div>
    <div v-show="genelYetkiliMi && tab === 'adetBirimi'">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">Adet Birimleri<button class="btn btn-primary btn-sm" @@click="adetBirimiEkle()"><i class="fas fa-plus"></i> Ekle</button></div>
            <table class="table mb-0"><thead><tr><th>Ad</th><th>Sira</th><th></th></tr></thead><tbody>
                <tr v-for="a in adetBirimleri" :key="a.id"><td>{{ a.ad }}</td><td>{{ a.sira }}</td><td><button class="btn btn-sm btn-outline-secondary" @@click="adetBirimiDuzenle(a)"><i class="fas fa-edit me-1"></i> Düzenle</button> <button class="btn btn-sm btn-outline-danger" @@click="adetBirimiSil(a.id)"><i class="fas fa-trash me-1"></i> Sil</button></td></tr>
            </tbody></table>
        </div>
    </div>
    <div v-show="genelYetkiliMi && tab === 'sahaDenetimKategori'">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">Saha Denetim Kategorileri<button class="btn btn-primary btn-sm" @@click="sdKategoriEkle()"><i class="fas fa-plus"></i> Ekle</button></div>
            <table class="table mb-0"><thead><tr><th>Kategori Adı</th><th></th></tr></thead><tbody>
                <tr v-for="k in sdKategoriler" :key="k.id"><td>{{ k.ad }}</td><td><button class="btn btn-sm btn-outline-secondary" @@click="sdKategoriDuzenle(k)"><i class="fas fa-edit me-1"></i> Düzenle</button> <button class="btn btn-sm btn-outline-danger" @@click="sdKategoriSil(k.id)"><i class="fas fa-trash me-1"></i> Sil</button></td></tr>
            </tbody></table>
        </div>
    </div>
    <div class="modal fade" id="durumModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">{{ durumForm.id ? 'Düzenle' : 'Yeni Durum' }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div class="mb-3">
                <label class="form-label">Ad</label>
                <input v-model="durumForm.ad" class="form-control" />
            </div>
            <div>
                <label class="form-label">Sıra</label>
                <input v-model.number="durumForm.sira" type="number" class="form-control" />
            </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-1"></i> İptal</button><button type="button" class="btn btn-primary" @@click="durumKaydet"><i class="fas fa-save me-1"></i> Kaydet</button></div>
    </div></div></div>
    <div class="modal fade" id="kategoriModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">{{ kategoriForm.id ? 'Düzenle' : 'Yeni Kategori' }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div class="mb-3">
                <label class="form-label">Ad</label>
                <input v-model="kategoriForm.ad" class="form-control" />
            </div>
            <div>
                <label class="form-label">Sıra</label>
                <input v-model.number="kategoriForm.sira" type="number" class="form-control" />
            </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-1"></i> İptal</button><button type="button" class="btn btn-primary" @@click="kategoriKaydet"><i class="fas fa-save me-1"></i> Kaydet</button></div>
    </div></div></div>
    <div class="modal fade" id="adetBirimiModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">{{ adetBirimiForm.id ? 'Düzenle' : 'Yeni Adet Birimi' }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div class="mb-3">
                <label class="form-label">Ad</label>
                <input v-model="adetBirimiForm.ad" class="form-control" />
            </div>
            <div>
                <label class="form-label">Sıra</label>
                <input v-model.number="adetBirimiForm.sira" type="number" class="form-control" />
            </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-1"></i> İptal</button><button type="button" class="btn btn-primary" @@click="adetBirimiKaydet"><i class="fas fa-save me-1"></i> Kaydet</button></div>
    </div></div></div>
    <div class="modal fade" id="sdKategoriModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">{{ sdKategoriForm.id ? 'Düzenle' : 'Yeni Kategori' }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div class="mb-3">
                <label class="form-label">Kategori Adı</label>
                <input v-model="sdKategoriForm.ad" class="form-control" />
            </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-1"></i> İptal</button><button type="button" class="btn btn-primary" @@click="sdKategoriKaydet"><i class="fas fa-save me-1"></i> Kaydet</button></div>
    </div></div></div>
    </div>
</div>
@section Scripts {
<script>
const { createApp } = Vue;
createApp({
    data() {
        var root = document.getElementById('parametre-app');
        var genelYetkiliMi = root && root.getAttribute('data-genel-yetkili') === 'true';
        return {
            genelYetkiliMi: genelYetkiliMi,
            tab: genelYetkiliMi ? 'durum' : 'kategori',
            durumlar: [],
            kategoriler: [],
            adetBirimleri: [],
            sdKategoriler: [],
            durumForm: { id: null, ad: '', sira: 0 },
            kategoriForm: { id: null, ad: '', sira: 0 },
            adetBirimiForm: { id: null, ad: '', sira: 0 },
            sdKategoriForm: { id: null, ad: '' }
        };
    },
    mounted() {
        var promises = [
            axios.get('/api/Parametre/kategoriler').then(r => { this.kategoriler = r.data; }),
            axios.get('/api/Parametre/adet-birimleri').then(r => { this.adetBirimleri = r.data; })
        ];
        if (this.genelYetkiliMi)
            promises.push(axios.get('/api/Parametre/durumlar').then(r => { this.durumlar = r.data; }));
        if (this.genelYetkiliMi)
            promises.push(axios.get('/api/Parametre/saha-denetim-kategorileri').then(r => { this.sdKategoriler = r.data; }));
        Promise.all(promises).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
    },
    methods: {
        durumYukle() { return axios.get('/api/Parametre/durumlar').then(r => { this.durumlar = r.data; }); },
        kategoriYukle() { return axios.get('/api/Parametre/kategoriler').then(r => { this.kategoriler = r.data; }); },
        adetBirimiYukle() { return axios.get('/api/Parametre/adet-birimleri').then(r => { this.adetBirimleri = r.data; }); },
        sdKategoriYukle() { return axios.get('/api/Parametre/saha-denetim-kategorileri').then(r => { this.sdKategoriler = r.data; }); },
        durumEkle() { this.durumForm = { id: null, ad: '', sira: this.durumlar.length + 1 }; new bootstrap.Modal(document.getElementById('durumModal')).show(); },
        durumDuzenle(d) { this.durumForm = { id: d.id, ad: d.ad, sira: d.sira }; new bootstrap.Modal(document.getElementById('durumModal')).show(); },
        durumKaydet() {
            var payload = { ad: this.durumForm.ad || '', sira: this.durumForm.sira || 0 };
            if (window.setPageLoading) window.setPageLoading(true);
            var p = this.durumForm.id ? axios.put('/api/Parametre/durumlar/' + this.durumForm.id, payload) : axios.post('/api/Parametre/durumlar', payload);
            p.then(() => this.durumYukle()).then(() => { bootstrap.Modal.getInstance(document.getElementById('durumModal')).hide(); if (window.setPageLoading) window.setPageLoading(false); }).catch(err => { if (window.setPageLoading) window.setPageLoading(false); alert(err.response?.data?.message || 'Kayıt işlemi başarısız.'); });
        },
        durumSil(id) {
            if (!confirm('Silinsin mi?')) return;
            if (window.setPageLoading) window.setPageLoading(true);
            axios.delete('/api/Parametre/durumlar/' + id).then(() => this.durumYukle()).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
        },
        kategoriEkle() { this.kategoriForm = { id: null, ad: '', sira: this.kategoriler.length + 1 }; new bootstrap.Modal(document.getElementById('kategoriModal')).show(); },
        kategoriDuzenle(k) { this.kategoriForm = { id: k.id, ad: k.ad, sira: k.sira }; new bootstrap.Modal(document.getElementById('kategoriModal')).show(); },
        kategoriKaydet() {
            var payload = { ad: this.kategoriForm.ad || '', sira: this.kategoriForm.sira || 0 };
            if (window.setPageLoading) window.setPageLoading(true);
            var p = this.kategoriForm.id ? axios.put('/api/Parametre/kategoriler/' + this.kategoriForm.id, payload) : axios.post('/api/Parametre/kategoriler', payload);
            p.then(() => this.kategoriYukle()).then(() => { bootstrap.Modal.getInstance(document.getElementById('kategoriModal')).hide(); if (window.setPageLoading) window.setPageLoading(false); }).catch(err => { if (window.setPageLoading) window.setPageLoading(false); alert(err.response?.data?.message || 'Kayıt işlemi başarısız.'); });
        },
        kategoriSil(id) {
            if (!confirm('Silinsin mi?')) return;
            if (window.setPageLoading) window.setPageLoading(true);
            axios.delete('/api/Parametre/kategoriler/' + id).then(() => this.kategoriYukle()).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
        },
        adetBirimiEkle() { this.adetBirimiForm = { id: null, ad: '', sira: this.adetBirimleri.length + 1 }; new bootstrap.Modal(document.getElementById('adetBirimiModal')).show(); },
        adetBirimiDuzenle(a) { this.adetBirimiForm = { id: a.id, ad: a.ad, sira: a.sira }; new bootstrap.Modal(document.getElementById('adetBirimiModal')).show(); },
        adetBirimiKaydet() {
            var payload = { ad: this.adetBirimiForm.ad || '', sira: this.adetBirimiForm.sira || 0 };
            if (window.setPageLoading) window.setPageLoading(true);
            var p = this.adetBirimiForm.id ? axios.put('/api/Parametre/adet-birimleri/' + this.adetBirimiForm.id, payload) : axios.post('/api/Parametre/adet-birimleri', payload);
            p.then(() => this.adetBirimiYukle()).then(() => { bootstrap.Modal.getInstance(document.getElementById('adetBirimiModal')).hide(); if (window.setPageLoading) window.setPageLoading(false); }).catch(err => { if (window.setPageLoading) window.setPageLoading(false); alert(err.response?.data?.message || 'Kayıt işlemi başarısız.'); });
        },
        adetBirimiSil(id) {
            if (!confirm('Silinsin mi?')) return;
            if (window.setPageLoading) window.setPageLoading(true);
            axios.delete('/api/Parametre/adet-birimleri/' + id).then(() => this.adetBirimiYukle()).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
        },

        sdKategoriEkle() { this.sdKategoriForm = { id: null, ad: '' }; new bootstrap.Modal(document.getElementById('sdKategoriModal')).show(); },
        sdKategoriDuzenle(k) { this.sdKategoriForm = { id: k.id, ad: k.ad }; new bootstrap.Modal(document.getElementById('sdKategoriModal')).show(); },
        sdKategoriKaydet() {
            var payload = { ad: this.sdKategoriForm.ad || '' };
            if (window.setPageLoading) window.setPageLoading(true);
            var p = this.sdKategoriForm.id
                ? axios.put('/api/Parametre/saha-denetim-kategorileri/' + this.sdKategoriForm.id, payload)
                : axios.post('/api/Parametre/saha-denetim-kategorileri', payload);
            p.then(() => this.sdKategoriYukle())
                .then(() => { bootstrap.Modal.getInstance(document.getElementById('sdKategoriModal')).hide(); if (window.setPageLoading) window.setPageLoading(false); })
                .catch(err => { if (window.setPageLoading) window.setPageLoading(false); alert(err.response?.data?.message || 'Kayıt işlemi başarısız.'); });
        },
        sdKategoriSil(id) {
            if (!confirm('Silinsin mi?')) return;
            if (window.setPageLoading) window.setPageLoading(true);
            axios.delete('/api/Parametre/saha-denetim-kategorileri/' + id)
                .then(() => this.sdKategoriYukle())
                .then(() => { if (window.setPageLoading) window.setPageLoading(false); })
                .catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
        }
    }
}).mount('#parametre-app');
</script>
}
