@{
    Layout = "_AdminLayout";
}
<style>
    #dashboard-app .table-responsive { overflow: visible !important; }
</style>
<div id="dashboard-app">
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-icon primary"><i class="fas fa-folder-open"></i></div>
                <div class="stat-card-label">Aktif Proje</div>
                <div class="stat-card-value">{{ aktifProjeler.length }}</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-icon warning"><i class="fas fa-list-check"></i></div>
                <div class="stat-card-label">Aktif Görev</div>
                <div class="stat-card-value">{{ toplamGorevAdet }}</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-card-icon success"><i class="fas fa-chart-pie"></i></div>
                <div class="stat-card-label">Görev Durumları</div>
                <div class="stat-card-value">{{ gorevDurumOzeti.length }}</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Projeler (Tamamlandı ve İptal Edildi hariç)</span>
                    <a href="/Projeler" class="btn btn-sm btn-outline-primary">Tüm Projeler</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Proje Adı</th>
                                <th>Durum</th>
                                <th>İlerleme</th>
                                <th>Planlanan Bitiş</th>
                                <th>Sorumlu</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr v-for="p in aktifProjeler" :key="p.id">
                                <td><a :href="'/Projeler/Detay/' + p.id">{{ p.ad }}</a></td>
                                <td><span class="badge bg-secondary">{{ p.projeDurumAd }}</span></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="width:80px"><div class="progress-bar" :style="{width: p.progressYuzde + '%'}"></div></div>
                                        <span>{{ p.progressYuzde }}%</span>
                                    </div>
                                </td>
                                <td>{{ formatDate(p.planlananBitisTarihi) }}</td>
                                <td>{{ p.sorumluAdSoyad || '-' }}</td>
                                <td>
                                    <div class="dropdown" data-bs-popper-config='{"strategy":"fixed"}'>
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">İşlemler</button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item text-success" :href="'/Projeler/Detay/' + p.id"><i class="fas fa-eye me-1"></i> Detay</a></li>
                                            <li><a class="dropdown-item text-primary" :href="'/Projeler/Edit/' + p.id"><i class="fas fa-edit me-1"></i> Güncelle</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                            <tr v-if="aktifProjeler.length === 0"><td colspan="6" class="text-center text-muted py-4">Aktif proje bulunamadı.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Görevler (Tamamlandı ve İptal Edildi hariç) — Statü ve Adet</span>
                    <a href="/Gorevler" class="btn btn-sm btn-outline-primary">Görevlere Git</a>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-3 align-items-center" v-if="gorevDurumOzeti.length">
                        <div v-for="s in gorevDurumOzeti" :key="s.durumAd" class="durum-ozet-pill">
                            <span class="durum-ozet-ad">{{ s.durumAd }}</span>
                            <span class="durum-ozet-adet">{{ s.adet }}</span>
                        </div>
                    </div>
                    <div v-else class="text-muted">Aktif görev yok.</div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
const { createApp } = Vue;
createApp({
    data() {
        return {
            aktifProjeler: [],
            gorevDurumOzeti: []
        };
    },
    computed: {
        toplamGorevAdet() {
            return this.gorevDurumOzeti.reduce((t, s) => t + s.adet, 0);
        }
    },
    mounted() {
        axios.get('/api/Dashboard').then(r => {
            const d = r.data;
            this.aktifProjeler = d.aktifProjeler || [];
            this.gorevDurumOzeti = d.gorevDurumOzeti || [];
        }).catch(e => console.error(e));
    },
    methods: {
        formatDate(d) { if (!d) return '-'; return new Date(d).toLocaleDateString('tr-TR'); }
    }
}).mount('#dashboard-app');
</script>
}
