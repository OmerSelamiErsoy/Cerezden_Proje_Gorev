@{
    Layout = "_AdminLayout";
}
<style>
    #dashboard-app .table-responsive { overflow: visible !important; }
    .dashboard-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%);
        border-radius: var(--radius-lg, 14px);
        padding: 1.5rem 1.75rem;
        margin-bottom: 1.75rem;
        color: #f1f5f9;
        box-shadow: 0 4px 20px rgba(15, 23, 42, 0.25);
    }
    .dashboard-hero h2 { font-size: 1.35rem; font-weight: 700; margin-bottom: 0.25rem; letter-spacing: -0.02em; }
    .dashboard-hero p { font-size: 0.875rem; color: #94a3b8; margin-bottom: 0; }
    .dashboard-section {
        margin-bottom: 1.75rem;
    }
    .dashboard-section-title {
        font-size: 0.75rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .dashboard-section-title.sorumlu { color: #0d9488; }
    .dashboard-stats-row { margin-bottom: 0.5rem; }
    .dashboard-projeler-wrap {
        background: #fff;
        border-radius: var(--radius-lg, 14px);
        box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.04), 0 1px 2px -1px rgb(0 0 0 / 0.04);
        border: 1px solid rgba(226, 232, 240, 0.9);
        overflow: hidden;
    }
    .dashboard-projeler-wrap .card-header {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        font-weight: 600;
        color: #1e293b;
        padding: 1rem 1.25rem;
    }
    .dashboard-projeler-wrap .table { margin-bottom: 0; }
    .dashboard-projeler-wrap .table thead th { font-size: 0.8125rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.03em; border-bottom: 1px solid #e2e8f0; padding: 0.75rem 1rem; }
    .dashboard-projeler-wrap .table tbody td { padding: 0.75rem 1rem; vertical-align: middle; }
    .dashboard-projeler-wrap .table tbody tr:hover { background: #f8fafc; }
    .dashboard-cta { margin-top: 1rem; }
    /* Durum kartları: ikon | durum adı | adet (yatay, kompakt) - Görevler ile aynı */
    #dashboard-app .dashboard-durum-section .stat-card {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.75rem;
        padding: 0.65rem 1rem;
        min-height: auto;
    }
    #dashboard-app .dashboard-durum-section .stat-card-icon {
        width: 38px;
        height: 38px;
        font-size: 1rem;
        margin-bottom: 0;
        flex-shrink: 0;
    }
    #dashboard-app .dashboard-durum-section .stat-card:hover .stat-card-icon { transform: none; }
    #dashboard-app .dashboard-durum-section .stat-card-label {
        margin-bottom: 0;
        flex: 1;
        font-size: 0.8125rem;
    }
    #dashboard-app .dashboard-durum-section .stat-card-value {
        font-size: 1.15rem;
        margin-bottom: 0 !important;
        flex-shrink: 0;
    }

    /* Notlar + Saha Denetim kartları */
    #dashboard-app .dash-grid-2 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }
    @@media (min-width: 992px) {
        #dashboard-app .dash-grid-2 { grid-template-columns: 1fr 1fr; }
    }
    #dashboard-app .dash-mini-card {
        background: #fff;
        border-radius: var(--radius-lg, 14px);
        box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.04), 0 1px 2px -1px rgb(0 0 0 / 0.04);
        border: 1px solid rgba(226, 232, 240, 0.9);
        overflow: hidden;
        height: 100%;
    }
    #dashboard-app .dash-mini-card .card-header {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 0.9rem 1.1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    #dashboard-app .dash-mini-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        color: #0f172a;
        letter-spacing: -0.01em;
    }
    #dashboard-app .dash-mini-sub {
        font-size: 0.8rem;
        color: #64748b;
        font-weight: 500;
    }
    #dashboard-app .dash-mini-body { padding: 1rem 1.1rem; }
    #dashboard-app .dash-kpi-row { display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom: 0.85rem; }
    #dashboard-app .dash-kpi {
        padding: 0.45rem 0.7rem;
        border-radius: 999px;
        background: #f1f5f9;
        color: #334155;
        border: 1px solid #e2e8f0;
        font-size: 0.8rem;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        white-space: nowrap;
    }
    #dashboard-app .dash-kpi strong { color:#0f172a; font-weight: 800; }
    #dashboard-app .dash-list { margin:0; padding:0; list-style:none; }
    #dashboard-app .dash-list li { padding: 0.55rem 0; border-top: 1px solid #f1f5f9; }
    #dashboard-app .dash-list li:first-child { border-top: 0; padding-top: 0; }
    #dashboard-app .dash-item-title { display:flex; gap:0.5rem; align-items:center; justify-content:space-between; }
    #dashboard-app .dash-item-title a { color:#0d9488; text-decoration:none; font-weight: 700; }
    #dashboard-app .dash-item-title a:hover { text-decoration: underline; color:#0f766e; }
    #dashboard-app .dash-item-meta { font-size:0.78rem; color:#64748b; margin-top: 0.15rem; display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center; }
    #dashboard-app .badge-soft {
        border-radius: 999px;
        padding: 0.2rem 0.5rem;
        font-size: 0.72rem;
        font-weight: 700;
        border: 1px solid transparent;
    }
    #dashboard-app .badge-soft.private { background:#eef2ff; color:#3730a3; border-color:#e0e7ff; }
    #dashboard-app .badge-soft.shared { background:#ecfeff; color:#155e75; border-color:#cffafe; }
</style>
<div id="dashboard-app" data-vue-page v-cloak>
    <div class="v-cloak-loading d-flex align-items-center justify-content-center py-5">
        <div class="w-100 text-center">
            <div class="small text-muted mb-2">Yükleniyor...</div>
            <div class="progress" style="max-width:260px;margin:0 auto;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:100%"></div>
            </div>
        </div>
    </div>
    <div class="v-cloak-hidden">
        <div class="dashboard-hero">
            <h2>Hoş Geldiniz</h2>
            <p>Aktif projeleriniz ve görev özetiniz aşağıda.</p>
        </div>

        <div class="dashboard-section">
            <div class="dashboard-section-title"><i class="fas fa-chart-pie"></i> Özet</div>
            <div class="row g-3 dashboard-stats-row">
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-card-icon primary"><i class="fas fa-folder-open"></i></div>
                        <div class="stat-card-label">Aktif Proje</div>
                        <div class="stat-card-value">{{ aktifProjeler.length }}</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-card-icon warning"><i class="fas fa-list-check"></i></div>
                        <div class="stat-card-label">Aktif Görev</div>
                        <div class="stat-card-value">{{ toplamGorevAdet }}</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="stat-card-icon success"><i class="fas fa-layer-group"></i></div>
                        <div class="stat-card-label">Görev Grupları</div>
                        <div class="stat-card-value">{{ gorevGrubuSayisi }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="dashboard-section">
            <div class="dashboard-section-title"><i class="fas fa-layer-group"></i> Notlar & Saha Denetim</div>
            <div class="dash-grid-2">
                <div class="dash-mini-card card">
                    <div class="card-header">
                        <div>
                            <div class="dash-mini-title"><i class="fas fa-note-sticky text-warning"></i> Notlar</div>
                            <div class="dash-mini-sub">Hızlı erişim ve son notlar</div>
                        </div>
                        <div class="d-flex gap-2">
                            <a class="btn btn-sm btn-outline-secondary" href="/Notlar/Yeni"><i class="fas fa-plus me-1"></i> Yeni</a>
                            <a class="btn btn-sm btn-outline-primary" href="/Notlar"><i class="fas fa-arrow-right me-1"></i> Notlar</a>
                        </div>
                    </div>
                    <div class="dash-mini-body">
                        <div class="dash-kpi-row">
                            <span class="dash-kpi"><i class="fas fa-note-sticky"></i> Toplam <strong>{{ notlar.toplam ?? 0 }}</strong></span>
                            <span class="dash-kpi"><i class="fas fa-user-lock"></i> Sadece ben <strong>{{ notlar.sadeceBen ?? 0 }}</strong></span>
                            <span class="dash-kpi"><i class="fas fa-user-group"></i> Paylaşımlı <strong>{{ notlar.paylasimli ?? 0 }}</strong></span>
                        </div>
                        <ul class="dash-list" v-if="(notlar.sonNotlar || []).length > 0">
                            <li v-for="n in notlar.sonNotlar" :key="n.id">
                                <div class="dash-item-title">
                                    <a :href="'/Notlar/Detay/' + n.id">{{ n.baslik }}</a>
                                    <span v-if="n.yetkiTipi === 1" class="badge-soft shared">Paylaşımlı</span>
                                    <span v-else class="badge-soft private">Sadece ben</span>
                                </div>
                                <div class="dash-item-meta">
                                    <span><i class="fas fa-calendar-alt me-1"></i>{{ formatDate(n.insertDate) }}</span>
                                    <span class="mx-1">•</span>
                                    <span><i class="fas fa-user me-1"></i>{{ n.olusturanAdSoyad || '-' }}</span>
                                </div>
                            </li>
                        </ul>
                        <div v-else class="text-muted small">Henüz not yok. “Yeni” ile ekleyebilirsiniz.</div>
                    </div>
                </div>

                <div class="dash-mini-card card">
                    <div class="card-header">
                        <div>
                            <div class="dash-mini-title"><i class="fas fa-clipboard-check text-primary"></i> Saha Denetim</div>
                            <div class="dash-mini-sub">Durum özeti ve son denetimler</div>
                        </div>
                        <div class="d-flex gap-2">
                            <a class="btn btn-sm btn-outline-secondary" href="/SahaDenetim/Yeni"><i class="fas fa-plus me-1"></i> Yeni</a>
                            <a class="btn btn-sm btn-outline-primary" href="/SahaDenetim"><i class="fas fa-arrow-right me-1"></i> Liste</a>
                        </div>
                    </div>
                    <div class="dash-mini-body">
                        <div class="dash-kpi-row">
                            <span class="dash-kpi"><i class="fas fa-clipboard-check"></i> Toplam <strong>{{ sahaDenetim.toplam ?? 0 }}</strong></span>
                            <span class="dash-kpi"><i class="fas fa-circle-play"></i> Açık <strong>{{ sahaDenetim.acik ?? 0 }}</strong></span>
                            <span class="dash-kpi"><i class="fas fa-circle-check"></i> Kapalı <strong>{{ sahaDenetim.kapali ?? 0 }}</strong></span>
                        </div>
                        <ul class="dash-list" v-if="(sahaDenetim.sonDenetimler || []).length > 0">
                            <li v-for="d in sahaDenetim.sonDenetimler" :key="d.id">
                                <div class="dash-item-title">
                                    <a :href="'/SahaDenetim/Detay/' + d.id">{{ d.ad }}</a>
                                    <span v-if="d.kapaliMi" class="badge badge-sd-closed">Kapalı</span>
                                    <span v-else class="badge badge-sd-open">Açık</span>
                                </div>
                                <div class="dash-item-meta">
                                    <span><i class="fas fa-calendar-alt me-1"></i>{{ formatDate(d.kayitTarihi) }}</span>
                                    <span class="mx-1">•</span>
                                    <span><i class="fas fa-location-dot me-1"></i>{{ d.lokasyonAdi ? (d.lokasyonAdi + ' - ' + (d.lokasyonId || '')) : '-' }}</span>
                                    <span class="mx-1">•</span>
                                    <span><i class="fas fa-list-ol me-1"></i>Adım: {{ d.adimSayisi ?? 0 }}</span>
                                </div>
                            </li>
                        </ul>
                        <div v-else class="text-muted small">Henüz denetim yok. “Yeni” ile ekleyebilirsiniz.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="dashboard-section">
            <div class="dashboard-section-title"><i class="fas fa-folder-open"></i> Projeler (Tamamlandı ve İptal hariç)</div>
            <div class="dashboard-projeler-wrap card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Aktif Projeler</span>
                    <a href="/Projeler" class="btn btn-sm btn-outline-primary"><i class="fas fa-folder-open me-1"></i> Tüm Projeler</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Proje Adı</th>
                                <th>Durum</th>
                                <th>İlerleme</th>
                                <th>Planlanan Bitiş</th>
                                <th>Toplam Maliyet</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr v-for="p in aktifProjeler" :key="p.id">
                                <td><a :href="'/Projeler/Detay/' + p.id" class="fw-medium text-decoration-none">{{ p.ad }}</a></td>
                                <td><span class="badge bg-secondary">{{ p.projeDurumAd }}</span></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="width:80px;height:6px"><div class="progress-bar" :style="{width: p.progressYuzde + '%'}"></div></div>
                                        <span class="small">{{ p.progressYuzde }}%</span>
                                    </div>
                                </td>
                                <td class="small">{{ formatDate(p.planlananBitisTarihi) }}</td>
                                <td class="small fw-semibold">{{ formatMoney(p.toplamMaliyet) }}</td>
                                <td>
                                    <div class="dropdown" data-bs-popper-config='{"strategy":"fixed"}'>
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown"><i class="fas fa-cog me-1"></i> İşlemler</button>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item text-success" :href="'/Projeler/Detay/' + p.id"><i class="fas fa-eye me-1"></i> Detay</a></li>
                                            <li><a class="dropdown-item text-primary" :href="'/Projeler/Edit/' + p.id"><i class="fas fa-edit me-1"></i> Güncelle</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                            <tr v-if="aktifProjeler.length === 0"><td colspan="6" class="text-center text-muted py-5">Aktif proje bulunamadı.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
const { createApp } = Vue;
createApp({
    data() {
        return {
            aktifProjeler: [],
            gorevDurumOzeti: [],
            gorevGrubuSayisi: 0,
            genelYetkiliMi: false,
            notlar: { toplam: 0, sadeceBen: 0, paylasimli: 0, sonNotlar: [] },
            sahaDenetim: { toplam: 0, acik: 0, kapali: 0, sonDenetimler: [] }
        };
    },
    computed: {
        toplamGorevAdet() {
            return this.gorevDurumOzeti.reduce((t, s) => t + s.adet, 0);
        }
    },
    mounted() {
        Promise.all([
            axios.get('/api/Dashboard').then(r => {
                const d = r.data;
                this.aktifProjeler = d.aktifProjeler || [];
                this.gorevDurumOzeti = d.gorevDurumOzeti || [];
                this.gorevGrubuSayisi = d.gorevGrubuSayisi ?? 0;
                this.genelYetkiliMi = !!d.meGenelYetkiliMi;
                this.notlar = d.notlar || this.notlar;
                this.sahaDenetim = d.sahaDenetim || this.sahaDenetim;
            })
        ]).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
    },
    methods: {
        formatDate(d) { if (!d) return '-'; return new Date(d).toLocaleDateString('tr-TR'); },
        formatMoney(v) {
            const n = Number(v || 0);
            if (isNaN(n)) return '₺0';
            return n.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' });
        }
    }
}).mount('#dashboard-app');
</script>
}
