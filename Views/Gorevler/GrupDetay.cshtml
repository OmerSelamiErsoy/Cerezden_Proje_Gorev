@{
    Layout = "_AdminLayout";
    var grupId = ViewData["GrupId"] as int?;
    var grupAd = ViewData["GrupAd"] as string ?? "Görev Grubu";
}
<style>
    .gorev-aciklama { color: #c2410c !important; }
    .aciklama-var-link {
        color: #c2410c !important;
        cursor: pointer;
        text-decoration: underline;
        font-weight: 600;
        animation: aciklama-blink 1.2s ease-in-out infinite;
    }
    .aciklama-var-link:hover { opacity: 0.9; }

    /* Compact kartlarda (İşlem Bekliyor/Beklemede/İşleme Alındı) açıklama linki mavi olsun */
    .kanban-card.compact .aciklama-var-link {
        color: #2563eb !important;
        animation: none;
        text-decoration: underline;
    }
    @@keyframes aciklama-blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }
    .atama-link { cursor: pointer; text-decoration: underline; }
    .atama-link:hover { opacity: 0.85; }
    .tamamlanan-iptal-card .tamamlanan-iptal-item {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
        background: #fff;
        transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    }
    .tamamlanan-iptal-card .tamamlanan-iptal-item:hover {
        box-shadow: 0 8px 20px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
        border-color: #cbd5e1;
    }
    .tamamlanan-iptal-card .tamamlanan-item {
        border-left: 4px solid #16a34a;
    }
    .tamamlanan-iptal-card .iptal-item {
        border-left: 4px solid #dc2626;
    }
    .yorum-item:last-child { border-bottom: none !important; }
    .yorum-avatar {
        width: 32px;
        height: 32px;
        border-radius: 999px;
        background: #0d9488;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 0.9rem;
        font-weight: 600;
        flex-shrink: 0;
    }
    /* Paylaşılacak Kişiler - modern checkbox listesi */
    .paylasilacak-kisiler-list {
        max-height: 220px;
        overflow-y: auto;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 8px;
        background: #fafafa;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s ease;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item:hover {
        background: #f1f5f9;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item .custom-checkbox-wrap {
        flex-shrink: 0;
        width: 22px;
        height: 22px;
        position: relative;
        border-radius: 6px;
        border: 2px solid #cbd5e1;
        background: #fff;
        transition: border-color 0.2s, background 0.2s;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item.selected .custom-checkbox-wrap {
        background: #3b82f6;
        border-color: #3b82f6;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item .custom-checkbox-wrap .check-icon {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item.selected .custom-checkbox-wrap .check-icon {
        opacity: 1;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item .custom-checkbox-wrap .check-icon svg {
        width: 14px;
        height: 14px;
        stroke: #fff;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item .kisi-adi {
        flex: 1;
        font-weight: 500;
        color: #1e293b;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item .kisi-ceptel {
        font-size: 0.875rem;
        color: #64748b;
    }

    /* Kanban kartları: aktif kolonlarda compact/accordion görünüm */
    .kanban-card.compact {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    }
    .kanban-card.compact .card-body {
        padding: 0.6rem 0.75rem !important;
    }
    .kanban-compact-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
        cursor: pointer;
        user-select: none;
    }
    .kanban-compact-title {
        font-weight: 800;
        font-size: 0.86rem;
        color: #0f172a;
        line-height: 1.2;
    }
    .kanban-compact-meta {
        font-size: 0.78rem;
        color: #64748b;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 6px;
        align-items: center;
    }
    .kanban-compact-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 999px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        color: #334155;
        font-size: 0.75rem;
        font-weight: 700;
        white-space: nowrap;
    }
    .kanban-compact-actions {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
        margin-left: 8px;
    }
    .kanban-compact-actions a { text-decoration: none; }
    .kanban-compact-chevron { color: #94a3b8; }
    .kanban-compact-body {
        border-top: 1px dashed #e2e8f0;
        margin-top: 10px;
        padding-top: 10px;
    }
</style>
<div id="gorevler-page" data-vue-page>
<div id="gorevler-app" class="gorevler-app" data-grup-id="@(grupId?.ToString() ?? "")" v-cloak>
    <div class="v-cloak-loading d-flex align-items-center justify-content-center py-5">
        <div class="w-100 text-center">
            <div class="small text-muted mb-2">Yükleniyor...</div>
            <div class="progress" style="max-width:260px;margin:0 auto;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:100%"></div>
            </div>
        </div>
    </div>
    <div class="v-cloak-hidden">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a href="/Gorevler" class="btn btn-outline-secondary btn-sm me-2"><i class="fas fa-arrow-left"></i> Gruplar</a>
            <span class="fw-medium">Grup görevleri - @grupAd</span>
        </div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#gorevModal" @@click="yeniGorev()"><i class="fas fa-plus me-1"></i> Yeni Görev</button>
    </div>
    <div class="row g-4 mb-4" v-if="kanbanKolonlari.length">
        <div v-for="kolon in kanbanKolonlari" :key="kolon.id" class="col">
            <div class="kanban-column card h-100">
                <div class="card-header">{{ kolon.ad }} ({{ (kanban.kartlar[kolon.id] || []).length }})</div>
                <div class="card-body p-3" style="min-height:280px">
                    <div v-for="kart in (kanban.kartlar && kanban.kartlar[kolon.id]) || []"
                         :key="kart.id"
                         class="kanban-card card"
                         :class="{ compact: isCompactKolon(kolon) }"
                         :style="kart.renk ? { borderLeft: '4px solid ' + kart.renk } : {}">

                        <!-- Compact: sadece aktif kolonlar -->
                        <div v-if="isCompactKolon(kolon)" class="card-body">
                            <div class="kanban-compact-head" data-bs-toggle="collapse" :data-bs-target="'#gk-c-' + kart.id" aria-expanded="false" @@click.prevent>
                                <div class="w-100">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div class="kanban-compact-title" :title="kart.ad">{{ kisaMetin(kart.ad, 55) }}</div>
                                        <div class="kanban-compact-actions">
                                            <a href="#" @@click.stop.prevent="yorumAc(kart)" class="text-decoration-none small" title="Yorumlar">
                                                <i class="fas fa-comment" :class="(kart.yorumSayisi || 0) > 0 ? 'text-danger' : 'text-success'"></i>
                                                <span class="ms-1">{{ (kart.yorumSayisi || 0) > 0 ? ('Mesaj (' + kart.yorumSayisi + ')') : 'mesaj yaz' }}</span>
                                            </a>
                                            <i class="fas fa-chevron-down kanban-compact-chevron"></i>
                                        </div>
                                    </div>

                                    <div class="kanban-compact-meta">
                                        <span v-if="kart.aciklama" class="kanban-compact-pill">
                                            <i class="fas fa-circle-info"></i>
                                            <a href="#" class="aciklama-var-link" @@click.stop.prevent="aciklamaPopupAc(kart)">Açıklama var</a>
                                        </span>
                                        <span class="kanban-compact-pill">
                                            <i class="fas fa-user"></i> Sorumlu: <span class="text-danger fw-medium">{{ kart.sorumluAdSoyad || '-' }}</span>
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="collapse" :id="'gk-c-' + kart.id">
                                <div class="kanban-compact-body">
                                    <div class="small text-muted mb-2">Oluşturan: {{ kart.olusturanAdSoyad }} - {{ formatDate(kart.olusturmaTarihi) }}</div>

                                    <div class="small text-muted mb-2">
                                        <span v-if="kart.turu === 0">Atama: Kendine atanmış</span>
                                        <template v-else-if="kart.turu === 1">
                                            <span v-if="me && me.genelYetkiliMi" class="atama-link" @@click.prevent="atananlarAc(kart)" title="Paylaşılan kişiler">Paylaşılan Kişiler: ({{ (kart.atananlar || []).length }})</span>
                                            <span v-else-if="kart.olusturanKullaniciId !== me?.kullaniciId">Paylaşılan Kişiler: Bana Paylaşıldı</span>
                                            <span v-else class="atama-link" @@click.prevent="atananlarAc(kart)" title="Paylaşılan kişiler">Paylaşılan Kişiler: ({{ (kart.atananlar || []).length }})</span>
                                        </template>
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label small text-muted mb-1">Durum güncelle</label>
                                        <select v-model="kart.durumId" @@change="durumGuncelle(kart)" class="form-select form-select-sm">
                                            <option v-for="s in kanban.durumlar" :key="s.id" :value="s.id">{{ s.ad }}</option>
                                        </select>
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="dropdown">
                                            <a href="#" class="text-secondary p-1" data-bs-toggle="dropdown" title="Renk" @@click.prevent><i class="fas fa-palette"></i></a>
                                            <ul class="dropdown-menu dropdown-menu-start">
                                                <li class="px-3 py-2 small fw-medium">Renk belirle</li>
                                                <li class="px-2 pb-2">
                                                    <div class="d-flex flex-wrap gap-1">
                                                        <button v-for="c in renkPaleti" :key="c" type="button" class="btn rounded-circle p-2 border" :style="{ background: c }" @@click="renkSecildi(kart, c)" title="Renk seç"></button>
                                                        <button type="button" class="btn btn-outline-secondary btn-sm" @@click="renkSecildi(kart, null)"><i class="fas fa-eraser me-1"></i> Kaldır</button>
                                                    </div>
                                                </li>
                                            </ul>
                                        </div>
                                        <div class="dropdown">
                                            <a href="#" class="text-secondary p-1" data-bs-toggle="dropdown" title="İşlemler" @@click.prevent><i class="fas fa-cog"></i></a>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li><a class="dropdown-item" href="#" @@click.prevent="atananlarAc(kart)"><i class="fas fa-users me-1"></i> Paylaşılan Kişiler</a></li>
                                                <li><a class="dropdown-item" href="#" @@click.prevent="logAc(kart)">Log</a></li>
                                                <li><a class="dropdown-item" href="#" @@click.prevent="gorevDuzenle(kart)">Güncelle</a></li>
                                                <li><a class="dropdown-item text-danger" href="#" @@click.prevent="gorevSil(kart)">Sil</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Diğer kolonlar: eski görünüm -->
                        <div v-else class="card-body p-2">
                            <div class="d-flex justify-content-between align-items-start">
                                <strong class="small" :title="kart.ad">{{ kisaMetin(kart.ad, 40) }}</strong>
                                <a href="#" @@click.prevent="yorumAc(kart)" class="text-decoration-none small" title="Yorumlar"><i class="fas fa-comment" :class="(kart.yorumSayisi || 0) > 0 ? 'text-danger' : 'text-success'"></i><span v-if="(kart.yorumSayisi || 0) > 0"> - Mesaj ({{ kart.yorumSayisi }})</span><span v-else> - mesaj yaz</span></a>
                            </div>
                            <p v-if="kart.aciklama" class="small mb-1">
                                <a href="#" class="aciklama-var-link" @@click.prevent="aciklamaPopupAc(kart)">Açıklama Var!</a>
                            </p>
                            <div class="small text-muted">Oluşturan: {{ kart.olusturanAdSoyad }} - {{ formatDate(kart.olusturmaTarihi) }}</div>
                            <div class="small text-muted">Sorumlu kişi: <span class="text-danger fw-medium">{{ kart.sorumluAdSoyad || '-' }}</span></div>
                            <div class="small text-muted">
                                <span v-if="kart.turu === 0">Atama: Kendine atanmış</span>
                                <template v-else-if="kart.turu === 1">
                                    <span v-if="me && me.genelYetkiliMi" class="atama-link" @@click.prevent="atananlarAc(kart)" title="Paylaşılan kişiler">Paylaşılan Kişiler: ({{ (kart.atananlar || []).length }})</span>
                                    <span v-else-if="kart.olusturanKullaniciId !== me?.kullaniciId">Paylaşılan Kişiler: Bana Paylaşıldı</span>
                                    <span v-else class="atama-link" @@click.prevent="atananlarAc(kart)" title="Paylaşılan kişiler">Paylaşılan Kişiler: ({{ (kart.atananlar || []).length }})</span>
                                </template>
                            </div>
                            <div class="mt-2">
                                <select v-model="kart.durumId" @@change="durumGuncelle(kart)" class="form-select form-select-sm">
                                    <option v-for="s in kanban.durumlar" :key="s.id" :value="s.id">{{ s.ad }}</option>
                                </select>
                                <div class="d-flex justify-content-between align-items-center mt-1">
                                    <div class="dropdown">
                                        <a href="#" class="text-secondary p-1" data-bs-toggle="dropdown" title="Renk" @@click.prevent><i class="fas fa-palette"></i></a>
                                        <ul class="dropdown-menu dropdown-menu-start">
                                            <li class="px-3 py-2 small fw-medium">Renk belirle</li>
                                            <li class="px-2 pb-2">
                                                <div class="d-flex flex-wrap gap-1">
                                                    <button v-for="c in renkPaleti" :key="c" type="button" class="btn rounded-circle p-2 border" :style="{ background: c }" @@click="renkSecildi(kart, c)" title="Renk seç"></button>
                                                    <button type="button" class="btn btn-outline-secondary btn-sm" @@click="renkSecildi(kart, null)"><i class="fas fa-eraser me-1"></i> Kaldır</button>
                                                </div>
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="dropdown">
                                        <a href="#" class="text-secondary p-1" data-bs-toggle="dropdown" title="İşlemler" @@click.prevent><i class="fas fa-cog"></i></a>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item" href="#" @@click.prevent="atananlarAc(kart)"><i class="fas fa-users me-1"></i> Paylaşılan Kişiler</a></li>
                                            <li><a class="dropdown-item" href="#" @@click.prevent="logAc(kart)">Log</a></li>
                                            <li><a class="dropdown-item" href="#" @@click.prevent="gorevDuzenle(kart)">Güncelle</a></li>
                                            <li><a class="dropdown-item text-danger" href="#" @@click.prevent="gorevSil(kart)">Sil</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="card mt-4 tamamlanan-iptal-card" v-if="tamamlananlar.length || iptalEdilenler.length">
        <div class="card-header">Tamamlanan / İptal (Son 50)</div>
        <div class="card-body">
            <div v-if="tamamlananlar.length" class="mb-4">
                <h6 class="text-success mb-3"><i class="fas fa-check-circle me-1"></i> Tamamlanan</h6>
                <div class="row g-3">
                    <div v-for="k in tamamlananlar" :key="k.id" class="col-12 col-md-6 col-xl-4">
                        <div class="card tamamlanan-iptal-item tamamlanan-item">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div class="min-w-0 flex-grow-1">
                                        <div class="fw-medium text-truncate mb-1" :title="k.ad">{{ kisaMetin(k.ad, 40) }}</div>
                                        <div class="small text-muted mb-2">Oluşturan: {{ k.olusturanAdSoyad }} - {{ formatDate(k.olusturmaTarihi) }}</div>
                                        <div class="small text-muted mb-2">Sorumlu kişi: <span class="text-danger fw-medium">{{ k.sorumluAdSoyad || '-' }}</span></div>
                                        <div class="d-flex align-items-center flex-wrap gap-2">
                                            <a href="#" class="text-decoration-none small" @@click.prevent="yorumAc(k)"><i class="fas fa-comment" :class="(k.yorumSayisi || 0) > 0 ? 'text-danger' : 'text-success'"></i><span v-if="(k.yorumSayisi || 0) > 0"> - Mesaj ({{ k.yorumSayisi }})</span><span v-else> - mesaj yaz</span></a>
                                            <button type="button" class="btn btn-sm btn-outline-secondary py-0" @@click="logAc(k)"><i class="fas fa-history me-1"></i> Log</button>
                                        </div>
                                    </div>
                                    <div class="dropdown flex-shrink-0">
                                        <a href="#" class="btn btn-sm btn-light border rounded-circle p-1" data-bs-toggle="dropdown" title="İşlemler" @@click.prevent><i class="fas fa-cog text-secondary"></i></a>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item" href="#" @@click.prevent="gorevDuzenle(k)"><i class="fas fa-edit me-1"></i> Güncelle</a></li>
                                            <li><a class="dropdown-item text-danger" href="#" @@click.prevent="gorevSil(k)"><i class="fas fa-trash me-1"></i> Sil</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div v-if="iptalEdilenler.length">
                <h6 class="text-danger mb-3"><i class="fas fa-times-circle me-1"></i> İptal Edilenler</h6>
                <div class="row g-3">
                    <div v-for="k in iptalEdilenler" :key="k.id" class="col-12 col-md-6 col-xl-4">
                        <div class="card tamamlanan-iptal-item iptal-item">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div class="min-w-0 flex-grow-1">
                                        <div class="fw-medium text-truncate mb-1" :title="k.ad">{{ kisaMetin(k.ad, 40) }}</div>
                                        <div class="small text-muted mb-2">Oluşturan: {{ k.olusturanAdSoyad }} - {{ formatDate(k.olusturmaTarihi) }}</div>
                                        <div class="small text-muted mb-2">Sorumlu kişi: <span class="text-danger fw-medium">{{ k.sorumluAdSoyad || '-' }}</span></div>
                                        <div class="d-flex align-items-center flex-wrap gap-2">
                                            <a href="#" class="text-decoration-none small" @@click.prevent="yorumAc(k)"><i class="fas fa-comment" :class="(k.yorumSayisi || 0) > 0 ? 'text-danger' : 'text-success'"></i><span v-if="(k.yorumSayisi || 0) > 0"> - Mesaj ({{ k.yorumSayisi }})</span><span v-else> - mesaj yaz</span></a>
                                            <button type="button" class="btn btn-sm btn-outline-secondary py-0" @@click="logAc(k)"><i class="fas fa-history me-1"></i> Log</button>
                                        </div>
                                    </div>
                                    <div class="dropdown flex-shrink-0">
                                        <a href="#" class="btn btn-sm btn-light border rounded-circle p-1" data-bs-toggle="dropdown" title="İşlemler" @@click.prevent><i class="fas fa-cog text-secondary"></i></a>
                                        <ul class="dropdown-menu dropdown-menu-end">
                                            <li><a class="dropdown-item" href="#" @@click.prevent="gorevDuzenle(k)"><i class="fas fa-edit me-1"></i> Güncelle</a></li>
                                            <li><a class="dropdown-item text-danger" href="#" @@click.prevent="gorevSil(k)"><i class="fas fa-trash me-1"></i> Sil</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>

    <div class="modal fade" id="atananlarModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Paylaşılan Kişiler - {{ atananlarGorevAd }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div class="mb-3">
                <label class="form-label small text-muted mb-0">Tür</label>
                <div class="fw-medium">{{ atananlarTuruMetin }}</div>
            </div>
            <div v-if="atananlarTuruMetin === 'Kişilere'">
                <label class="form-label small text-muted mb-1">Paylaşılan Kişiler</label>
                <ul v-if="atananlarListesi.length" class="list-group list-group-flush">
                    <li v-for="ad in atananlarListesi" :key="ad" class="list-group-item py-2">{{ ad }}</li>
                </ul>
                <p v-else class="text-muted small mb-0">Bu göreve henüz kimse atanmamış.</p>
            </div>
        </div>
    </div></div></div>

    <div class="modal fade" id="aciklamaModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Açıklama - {{ aciklamaPopupAd }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <p class="mb-0 text-break" style="white-space: pre-wrap;">{{ aciklamaPopupMetin }}</p>
        </div>
    </div></div></div>

    <div class="modal fade" id="logModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Durum Log - {{ logGorevAd }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div v-if="durumLog.length === 0" class="text-muted">Henüz durum değişikliği yok.</div>
            <ul v-else class="list-group list-group-flush">
                <li v-for="l in durumLog" :key="l.id" class="list-group-item d-flex justify-content-between align-items-start">
                    <div>
                        <strong>{{ l.degistirenAdSoyad }}{{ (l.degistirenCepTel != null && l.degistirenCepTel !== '') ? ' - ' + l.degistirenCepTel : '' }}</strong> · {{ formatDate(l.degistirmeTarihi) }}
                        <div class="small text-muted">{{ l.eskiDurumAd || '(yok)' }} → {{ l.yeniDurumAd }}</div>
                    </div>
                </li>
            </ul>
        </div>
    </div></div></div>

    <div class="modal fade" id="gorevModal" tabindex="-1">
        <div class="modal-dialog"><div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">{{ gorevForm.id ? 'Görev Düzenle' : 'Yeni Görev' }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-2"><label class="form-label">Görev Adı *</label><input v-model="gorevForm.ad" class="form-control" /></div>
                <div class="mb-2"><label class="form-label">Açıklama</label><textarea v-model="gorevForm.aciklama" class="form-control" rows="2"></textarea></div>
                <div class="mb-2" v-if="gorevForm.id"><label class="form-label">Durum</label><select v-model="gorevForm.durumId" class="form-select"><option v-for="d in kanban.durumlar" :key="d.id" :value="d.id">{{ d.ad }}</option></select></div>
                <div class="mb-2"><label class="form-label">Tür</label><select v-model="gorevForm.turu" class="form-select" @@change="gorevFormTuruDegisti"><option :value="0">Kendime</option><option :value="1">Kişilere</option></select></div>
                <div class="mb-2" v-if="gorevForm.turu === 1"><label class="form-label">Sorumlu Kişi *</label><select v-model="gorevForm.sorumluKullaniciId" class="form-select" required><option :value="null">Seçiniz</option><option v-for="k in kullanicilar" :key="k.id" :value="k.id">{{ k.adSoyad }} - {{ k.cepTel || '-' }}</option></select></div>
                <div class="mb-2" v-if="gorevForm.turu === 1">
                    <label class="form-label">Paylaşılacak Kişiler</label>
                    <div class="paylasilacak-kisiler-list">
                        <div v-for="k in kullanicilar" :key="k.id" class="paylasilacak-kisi-item" :class="{ selected: (gorevForm.atananKullaniciIds || []).indexOf(k.id) !== -1 }" @@click="atananKullaniciToggle(k)">
                            <div class="custom-checkbox-wrap">
                                <span class="check-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
                            </div>
                            <span class="kisi-adi">{{ k.adSoyad }}</span>
                            <span class="kisi-ceptel">{{ k.cepTel || '-' }}</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-1"></i> İptal</button><button type="button" class="btn btn-primary" @@click="gorevKaydet"><i class="fas fa-save me-1"></i> Kaydet</button></div>
        </div></div>
    </div>

    <div class="modal fade" id="yorumModal" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Yorumlar - {{ seciliGorev?.ad }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div v-if="!gorevYorumlar.length" class="text-muted small mb-3">Henüz yorum yok. İlk yorumu siz yazın.</div>
            <div v-for="y in gorevYorumlar" :key="y.id" class="yorum-item d-flex pb-3 mb-3 border-bottom">
                <div class="yorum-avatar me-3">
                    <span>{{ (y.yazanAdSoyad || '?').substring(0,1).toUpperCase() }}</span>
                </div>
                <div class="flex-grow-1 min-w-0">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <div class="fw-semibold small text-truncate">{{ y.yazanAdSoyad || 'Bilinmeyen kullanıcı' }}{{ (y.yazanCepTel != null && y.yazanCepTel !== '') ? ' - ' + y.yazanCepTel : '' }}</div>
                        <div class="small text-muted ms-2">{{ formatDate(y.insertDate) }}</div>
                    </div>
                    <p class="mb-1 small">{{ y.yorumMetni }}</p>
                    <div v-if="y.dosyalar && y.dosyalar.length" class="small mt-1">
                        <a v-for="f in y.dosyalar" :key="f.id" :href="f.dosyaYolu" target="_blank" class="me-2">{{ f.dosyaAdi }}</a>
                    </div>
                </div>
            </div>
            <div class="mt-2">
                <label class="form-label small text-muted">Yeni yorum</label>
                <textarea v-model="yeniYorum" class="form-control mb-2" rows="2" placeholder="Yorum yazın..."></textarea>
                <div class="d-flex justify-content-end">
                    <button class="btn btn-primary btn-sm" @@click="yorumGonder"><i class="fas fa-paper-plane me-1"></i> Gönder</button>
                </div>
            </div>
        </div>
    </div></div></div>

</div>
</div>
@section Scripts {
<script>
const { createApp } = Vue;
const el = document.getElementById('gorevler-app');
const grupId = el && el.dataset.grupId ? parseInt(el.dataset.grupId, 10) : null;
createApp({
    data() {
        return {
            grupId,
            kanban: { durumlar: [], kartlar: {}, tamamlananIptalSon50: [], me: null },
            me: null,
            kullanicilar: [],
            gorevForm: { id: null, ad: '', aciklama: '', durumId: null, turu: 0, atananKullaniciIds: [], sorumluKullaniciId: null, gorevGrubuId: grupId },
            duzenlenenKart: null,
            seciliGorev: null,
            gorevYorumlar: [],
            yeniYorum: '',
            renkPaleti: ['#ef4444','#f59e0b','#10b981','#3b82f6','#8b5cf6','#ec4899'],
            durumLog: [],
            logGorevAd: '',
            atananlarGorevAd: '',
            atananlarTuru: 0,
            atananlarListesi: [],
            aciklamaPopupAd: '',
            aciklamaPopupMetin: ''
        };
    },
    computed: {
        atananlarTuruMetin() { return this.atananlarTuru === 1 ? 'Kişilere' : 'Kendime'; },
        kanbanKolonlari() { return (this.kanban.durumlar || []).filter(d => d.id !== 4 && d.id !== 5); },
        tamamlananlar() { return (this.kanban.tamamlananIptalSon50 || []).filter(k => k.durumId === 5); },
        iptalEdilenler() { return (this.kanban.tamamlananIptalSon50 || []).filter(k => k.durumId === 4); }
    },
    mounted() {
        const p1 = this.yukle();
        const p2 = axios.get('/api/Kullanicilar').then(r => { this.kullanicilar = r.data; });
        Promise.all([p1, p2]).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
    },
    methods: {
        isCompactKolon(kolon) {
            const ad = (kolon && kolon.ad) ? String(kolon.ad) : '';
            // Sadece bu kolonlarda görev kartı dar/accordion görünsün
            return ad.includes('İşlem Bekliyor') || ad.includes('Beklemede') || ad.includes('İşleme Alındı');
        },
        yukle() {
            const url = grupId != null ? '/api/Gorevler/kanban?grupId=' + grupId : '/api/Gorevler/kanban';
            return axios.get(url).then(r => { this.kanban = r.data; this.me = r.data.me || null; });
        },
        kisaMetin(text, maxLen) {
            if (!text) return '';
            const s = String(text);
            const m = (maxLen == null || isNaN(maxLen)) ? 40 : Number(maxLen);
            return s.length > m ? (s.substring(0, m) + '...') : s;
        },
        formatDate(d) { if (!d) return '-'; return new Date(d).toLocaleString('tr-TR'); },
        yeniGorev() { this.gorevForm = { id: null, ad: '', aciklama: '', durumId: null, turu: 0, atananKullaniciIds: [], sorumluKullaniciId: this.me?.kullaniciId ?? null, gorevGrubuId: this.grupId }; },
        gorevFormTuruDegisti() { if (this.gorevForm.turu === 0) this.gorevForm.sorumluKullaniciId = this.me?.kullaniciId ?? null; },
        atananKullaniciToggle(k) {
            const arr = this.gorevForm.atananKullaniciIds || [];
            const idx = arr.indexOf(k.id);
            if (idx === -1) this.gorevForm.atananKullaniciIds = [...arr, k.id];
            else this.gorevForm.atananKullaniciIds = arr.filter(id => id !== k.id);
        },
        gorevKaydet() {
            if (!this.gorevForm.ad.trim()) return;
            if (this.gorevForm.turu === 1 && (!this.gorevForm.sorumluKullaniciId || this.gorevForm.sorumluKullaniciId === '')) return;
            if (window.setPageLoading) window.setPageLoading(true);
            const finish = () => { this.duzenlenenKart = null; bootstrap.Modal.getInstance(document.getElementById('gorevModal')).hide(); if (window.setPageLoading) window.setPageLoading(false); };
            if (this.gorevForm.id) {
                const k = this.duzenlenenKart;
                if (!k) return;
                const durumId = this.gorevForm.durumId != null ? this.gorevForm.durumId : k.durumId;
                const payload = {
                    ad: this.gorevForm.ad,
                    aciklama: this.gorevForm.aciklama || '',
                    durumId: durumId,
                    turu: this.gorevForm.turu,
                    atananKullaniciIds: this.gorevForm.turu === 1 ? (this.gorevForm.atananKullaniciIds || []) : [],
                    sorumluKullaniciId: this.gorevForm.turu === 0 ? (this.me?.kullaniciId ?? null) : (this.gorevForm.sorumluKullaniciId || null),
                    renk: k.renk || null
                };
                axios.put('/api/Gorevler/' + this.gorevForm.id, payload).then(() => this.yukle()).then(finish).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
            } else {
                const payload = { ad: this.gorevForm.ad, aciklama: this.gorevForm.aciklama, turu: this.gorevForm.turu, atananKullaniciIds: this.gorevForm.turu === 1 ? this.gorevForm.atananKullaniciIds : null, sorumluKullaniciId: this.gorevForm.turu === 0 ? (this.me?.kullaniciId ?? null) : (this.gorevForm.sorumluKullaniciId || null), gorevGrubuId: this.grupId };
                axios.post('/api/Gorevler', payload).then(() => this.yukle()).then(finish).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
            }
        },
        durumGuncelle(kart) {
            if (window.setPageLoading) window.setPageLoading(true);
            axios.put('/api/Gorevler/' + kart.id, { ad: kart.ad, aciklama: kart.aciklama || '', durumId: kart.durumId, renk: kart.renk || null }).then(() => this.yukle()).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
        },
        renkSecildi(kart, c) {
            kart.renk = c;
            if (window.setPageLoading) window.setPageLoading(true);
            axios.put('/api/Gorevler/' + kart.id, { ad: kart.ad, aciklama: kart.aciklama || '', durumId: kart.durumId, renk: c }).then(() => this.yukle()).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
        },
        gorevDuzenle(kart) {
            this.duzenlenenKart = kart;
            this.gorevForm = {
                id: kart.id,
                ad: kart.ad,
                aciklama: kart.aciklama || '',
                durumId: kart.durumId,
                turu: kart.turu ?? 0,
                atananKullaniciIds: Array.isArray(kart.atananKullaniciIds) ? [...kart.atananKullaniciIds] : [],
                sorumluKullaniciId: kart.sorumluKullaniciId ?? (kart.turu === 0 ? this.me?.kullaniciId : null),
                gorevGrubuId: this.grupId
            };
            new bootstrap.Modal(document.getElementById('gorevModal')).show();
        },
        gorevSil(kart) {
            if (!confirm('Bu görevi silmek istediğinize emin misiniz?')) return;
            if (window.setPageLoading) window.setPageLoading(true);
            axios.delete('/api/Gorevler/' + kart.id).then(() => this.yukle()).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
        },
        atananlarAc(kart) { this.atananlarGorevAd = kart.ad; this.atananlarTuru = kart.turu ?? 0; this.atananlarListesi = kart.atananlar && Array.isArray(kart.atananlar) ? kart.atananlar.filter(Boolean) : []; new bootstrap.Modal(document.getElementById('atananlarModal')).show(); },
        aciklamaPopupAc(kart) { this.aciklamaPopupAd = kart.ad; this.aciklamaPopupMetin = kart.aciklama || ''; new bootstrap.Modal(document.getElementById('aciklamaModal')).show(); },
        logAc(kart) { this.logGorevAd = kart.ad; this.durumLog = []; axios.get('/api/Gorevler/' + kart.id + '/durum-log').then(r => { this.durumLog = r.data; }); new bootstrap.Modal(document.getElementById('logModal')).show(); },
        yorumAc(kart) { this.seciliGorev = kart; this.yeniYorum = ''; axios.get('/api/Gorevler/' + kart.id + '/yorumlar').then(r => { this.gorevYorumlar = r.data; }); new bootstrap.Modal(document.getElementById('yorumModal')).show(); },
        yorumGonder() {
            if (!this.yeniYorum.trim() || !this.seciliGorev) return;
            if (window.setPageLoading) window.setPageLoading(true);
            axios.post('/api/Gorevler/' + this.seciliGorev.id + '/yorumlar', { yorumMetni: this.yeniYorum })
                .then(() => {
                    this.yeniYorum = '';
                    return axios.get('/api/Gorevler/' + this.seciliGorev.id + '/yorumlar').then(r => { this.gorevYorumlar = r.data; });
                })
                .then(() => this.yukle())
                .then(() => { if (window.setPageLoading) window.setPageLoading(false); })
                .catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
        }
    }
}).mount('#gorevler-page');
</script>
}
