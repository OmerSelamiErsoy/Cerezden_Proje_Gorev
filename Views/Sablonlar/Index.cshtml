@{
    Layout = "_AdminLayout";
}
<style>
    #sablon-app .table-responsive { overflow: visible !important; }
    /* Proje Başlat modal - Paylaşılacak Kişiler (Projeler/Create ile aynı) */
    #sablon-app #projeBaslatModal .paylasilacak-kisiler-list {
        max-height: 220px;
        overflow-y: auto;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 8px;
        background: #fafafa;
    }
    #sablon-app #projeBaslatModal .paylasilacak-kisiler-list .paylasilacak-kisi-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s ease;
    }
    #sablon-app #projeBaslatModal .paylasilacak-kisiler-list .paylasilacak-kisi-item:hover { background: #f1f5f9; }
    #sablon-app #projeBaslatModal .paylasilacak-kisi-item .custom-checkbox-wrap {
        flex-shrink: 0;
        width: 22px;
        height: 22px;
        position: relative;
        border-radius: 6px;
        border: 2px solid #cbd5e1;
        background: #fff;
        transition: border-color 0.2s, background 0.2s;
    }
    #sablon-app #projeBaslatModal .paylasilacak-kisi-item.selected .custom-checkbox-wrap { background: #3b82f6; border-color: #3b82f6; }
    #sablon-app #projeBaslatModal .paylasilacak-kisi-item .custom-checkbox-wrap .check-icon {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
    }
    #sablon-app #projeBaslatModal .paylasilacak-kisi-item.selected .custom-checkbox-wrap .check-icon { opacity: 1; }
    #sablon-app #projeBaslatModal .paylasilacak-kisi-item .custom-checkbox-wrap .check-icon svg { width: 14px; height: 14px; stroke: #fff; }
    #sablon-app #projeBaslatModal .paylasilacak-kisi-item .kisi-adi { flex: 1; font-weight: 500; color: #1e293b; }
    #sablon-app #projeBaslatModal .paylasilacak-kisi-item .kisi-ceptel { font-size: 0.875rem; color: #64748b; }
    /* Boş durum (şablon yok) - Projeler ile aynı tasarım */
    #sablon-app .sablon-empty {
        text-align: center;
        padding: 3rem 1.5rem;
        color: #64748b;
    }
    #sablon-app .sablon-empty .empty-icon { font-size: 2.5rem; color: #cbd5e1; margin-bottom: 1rem; }
    #sablon-app .sablon-empty .empty-title { font-weight: 600; color: #475569; margin-bottom: 0.25rem; }
    #sablon-app .sablon-empty .btn-primary { color: #fff !important; }
</style>
<div id="sablon-app" data-vue-page v-cloak>
    <div class="v-cloak-loading d-flex align-items-center justify-content-center py-5">
        <div class="w-100 text-center">
            <div class="small text-muted mb-2">Yükleniyor...</div>
            <div class="progress" style="max-width:260px;margin:0 auto;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:100%"></div>
            </div>
        </div>
    </div>
    <div class="v-cloak-hidden">
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            Proje Şablonları
            <a class="btn btn-primary btn-sm" href="/Sablonlar/Create"><i class="fas fa-plus me-1"></i> Yeni Şablon</a>
        </div>
        <div class="table-responsive">
            <table class="table mb-0">
                <thead><tr><th>Ad</th><th>Açıklama</th><th>Adım Sayısı</th><th>Proje</th><th>İşlemler</th></tr></thead>
                <tbody>
                    <tr v-for="s in sablonlar" :key="s.id">
                        <td>{{ s.ad }}</td>
                        <td>{{ s.aciklama || '-' }}</td>
                        <td>{{ s.detaySayisi }}</td>
                        <td>
                            <button class="btn btn-sm btn-success" @@click="projeBaslat(s)"><i class="fas fa-play me-1"></i> Proje Başlat</button>
                        </td>
                        <td>
                            <div class="dropdown" data-bs-popper-config='{"strategy":"fixed"}'>
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown"><i class="fas fa-cog me-1"></i> İşlemler</button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item text-success" :href="'/Sablonlar/Detay/' + s.id"><i class="fas fa-eye me-1"></i> Detay</a></li>
                                    <li><a class="dropdown-item text-primary" :href="'/Sablonlar/Edit/' + s.id"><i class="fas fa-edit me-1"></i> Düzenle</a></li>
                                    <li><a class="dropdown-item text-danger" href="#" @@click.prevent="sablonSil(s.id)"><i class="fas fa-trash me-1"></i> Sil</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                    <tr v-if="sablonlar.length === 0">
                        <td colspan="5" class="p-0">
                            <div class="sablon-empty">
                                <div class="empty-icon"><i class="fas fa-copy"></i></div>
                                <div class="empty-title">Henüz şablon yok</div>
                                <p class="small mb-3">İlk şablonunuzu oluşturmak için aşağıdaki butonu kullanın.</p>
                                <a class="btn btn-primary btn-sm text-white" href="/Sablonlar/Create"><i class="fas fa-plus me-1"></i> Yeni Şablon</a>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade" id="projeBaslatModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Proje Başlat - {{ seciliSablon?.ad }}</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
            <div class="mb-2"><label class="form-label">Proje Adı</label><input v-model="baslatForm.ad" class="form-control" :placeholder="seciliSablon && seciliSablon.ad" /></div>
            <div class="mb-2"><label class="form-label">Başlangıç Tarihi</label><input v-model="baslatForm.baslangicTarihi" type="date" class="form-control" /></div>
            <div class="mb-2"><label class="form-label">Planlanan Bitiş</label><input v-model="baslatForm.planlananBitisTarihi" type="date" class="form-control" /></div>
            <div class="mb-2"><label class="form-label">Sorumlu</label><select v-model="baslatForm.sorumluKullaniciId" class="form-select"><option :value="null">Seçiniz</option><option v-for="k in kullanicilar" :key="k.id" :value="k.id">{{ k.adSoyad }} - {{ k.cepTel || '-' }}</option></select></div>
            <div class="mb-2">
                <label class="form-label">Paylaşılacak Kişiler</label>
                <div>
                    <label class="me-3"><input type="radio" v-model="baslatForm.yetkiTipi" :value="0" /> Genel (tüm kullanıcılar)</label>
                    <label><input type="radio" v-model="baslatForm.yetkiTipi" :value="1" /> Kişi bazlı</label>
                </div>
                <div v-if="baslatForm.yetkiTipi === 1" class="mt-2">
                    <div class="paylasilacak-kisiler-list">
                        <div v-for="k in kullanicilar" :key="k.id" class="paylasilacak-kisi-item" :class="{ selected: (baslatForm.yetkiKullaniciIds || []).indexOf(k.id) !== -1 }" @@click="yetkiKullaniciToggle(k)">
                            <div class="custom-checkbox-wrap">
                                <span class="check-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
                            </div>
                            <span class="kisi-adi">{{ k.adSoyad }}</span>
                            <span class="kisi-ceptel">{{ k.cepTel || '-' }}</span>
                        </div>
                    </div>
                    <small class="text-muted">Birden fazla kişi seçebilirsiniz.</small>
                </div>
            </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="fas fa-times me-1"></i> İptal</button><button type="button" class="btn btn-primary" @@click="baslatOnay"><i class="fas fa-play me-1"></i> Proje Başlat</button></div>
    </div></div></div>
    </div>
</div>
@section Scripts {
<script>
const { createApp } = Vue;
createApp({
    data() {
        return {
            sablonlar: [],
            kategoriler: [],
            kullanicilar: [],
            seciliSablon: null,
            baslatForm: { ad: '', baslangicTarihi: null, planlananBitisTarihi: null, sorumluKullaniciId: null, yetkiTipi: 0, yetkiKullaniciIds: [] }
        };
    },
    mounted() {
        Promise.all([
            axios.get('/api/Sablon').then(r => { this.sablonlar = r.data; }),
            axios.get('/api/Parametre/kategoriler').then(r => { this.kategoriler = r.data; }),
            axios.get('/api/Kullanicilar').then(r => { this.kullanicilar = r.data; })
        ]).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
    },
    methods: {
        sablonYukle() { return axios.get('/api/Sablon').then(r => { this.sablonlar = r.data; }); },
        sablonSil(id) {
            if (!confirm('Şablon silinsin mi?')) return;
            if (window.setPageLoading) window.setPageLoading(true);
            axios.delete('/api/Sablon/' + id).then(() => this.sablonYukle()).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
        },
        projeBaslat(s) { this.seciliSablon = s; this.baslatForm = { ad: s.ad, baslangicTarihi: null, planlananBitisTarihi: null, sorumluKullaniciId: null, yetkiTipi: 0, yetkiKullaniciIds: [] }; new bootstrap.Modal(document.getElementById('projeBaslatModal')).show(); },
        yetkiKullaniciToggle(k) {
            var ids = this.baslatForm.yetkiKullaniciIds || [];
            var idx = ids.indexOf(k.id);
            if (idx === -1) ids.push(k.id);
            else ids.splice(idx, 1);
            this.baslatForm.yetkiKullaniciIds = ids;
        },
        baslatOnay() {
            const payload = { ad: this.baslatForm.ad || this.seciliSablon.ad, baslangicTarihi: this.baslatForm.baslangicTarihi || null, planlananBitisTarihi: this.baslatForm.planlananBitisTarihi || null, sorumluKullaniciId: this.baslatForm.sorumluKullaniciId, yetkiTipi: this.baslatForm.yetkiTipi, yetkiKullaniciIds: this.baslatForm.yetkiTipi === 1 ? this.baslatForm.yetkiKullaniciIds : null };
            axios.post('/api/Sablon/' + this.seciliSablon.id + '/proje-baslat', payload).then(r => { window.location.href = '/Projeler/Detay/' + r.data.id; });
        }
    }
}).mount('#sablon-app');
</script>
}
