@{
    Layout = "_AdminLayout";
}
<style>
    #projeler-app .table-responsive { overflow: visible !important; }
    .projeler-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .projeler-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0f172a;
        letter-spacing: -0.02em;
        margin-bottom: 0.25rem;
    }
    .projeler-page-desc {
        font-size: 0.875rem;
        color: #64748b;
    }
    .projeler-card {
        background: #fff;
        border-radius: var(--radius-lg, 14px);
        box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.04), 0 1px 2px -1px rgb(0 0 0 / 0.04);
        border: 1px solid rgba(226, 232, 240, 0.9);
        overflow: hidden;
    }
    .projeler-card .card-header {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        font-weight: 600;
        color: #1e293b;
        padding: 1rem 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .projeler-card .card-header .proje-sayisi {
        font-size: 0.8125rem;
        font-weight: 500;
        color: #64748b;
    }
    .projeler-card .table thead th {
        font-size: 0.75rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1px solid #e2e8f0;
        padding: 0.875rem 1.25rem;
    }
    .projeler-card .table tbody td {
        padding: 0.875rem 1.25rem;
        vertical-align: middle;
    }
    .projeler-card .table tbody tr:hover {
        background: #f8fafc;
    }
    .projeler-card .table tbody tr:not(:last-child) td {
        border-bottom: 1px solid #f1f5f9;
    }
    .projeler-card .table a[href*="Detay"] {
        font-weight: 600;
        color: #0d9488;
        text-decoration: none;
    }
    .projeler-card .table a[href*="Detay"]:hover {
        color: #0f766e;
        text-decoration: underline;
    }
    .projeler-card .progress {
        height: 6px;
        border-radius: 6px;
        background: #e2e8f0;
    }
    .projeler-card .progress-bar {
        border-radius: 6px;
        background: linear-gradient(90deg, #0d9488, #14b8a6);
    }
    .projeler-empty {
        text-align: center;
        padding: 3rem 1.5rem;
        color: #64748b;
    }
    .projeler-empty .empty-icon {
        font-size: 2.5rem;
        color: #cbd5e1;
        margin-bottom: 1rem;
    }
    .projeler-empty .empty-title { font-weight: 600; color: #475569; margin-bottom: 0.25rem; }
    .projeler-empty .btn-primary { color: #fff !important; }
</style>
<div id="projeler-app" data-vue-page v-cloak>
    <div class="v-cloak-loading d-flex align-items-center justify-content-center py-5">
        <div class="w-100 text-center">
            <div class="small text-muted mb-2">Yükleniyor...</div>
            <div class="progress" style="max-width:260px;margin:0 auto;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:100%"></div>
            </div>
        </div>
    </div>
    <div class="v-cloak-hidden">
        <div class="projeler-page-header">
            <div>
                <h1 class="projeler-page-title">Projeler</h1>
                <p class="projeler-page-desc">Tüm projeleri görüntüleyin ve yönetin.</p>
            </div>
            <a href="/Projeler/Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i> Yeni Proje</a>
        </div>

        <div class="projeler-card card">
            <div class="card-header">
                <span>Tüm Projeler</span>
                <span class="proje-sayisi">{{ projeler.length }} proje</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Proje Adı</th>
                            <th>Durum</th>
                            <th>İlerleme</th>
                            <th>Planlanan Bitiş</th>
                            <th>Toplam Maliyet</th>
                            <th style="width:120px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="p in projeler" :key="p.id">
                            <td><a :href="'/Projeler/Detay/' + p.id">{{ p.ad }}</a></td>
                            <td><span class="badge bg-secondary">{{ p.projeDurumAd }}</span></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="min-width:80px; max-width:120px"><div class="progress-bar" :style="{width: (p.progressYuzde || 0) + '%'}"></div></div>
                                    <span class="small fw-medium">{{ p.progressYuzde ?? 0 }}%</span>
                                </div>
                            </td>
                            <td class="small">{{ formatDate(p.planlananBitisTarihi) }}</td>
                            <td class="small fw-semibold">{{ formatMoney(p.toplamMaliyet) }}</td>
                            <td>
                                <div class="dropdown" data-bs-popper-config='{"strategy":"fixed"}'>
                                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown"><i class="fas fa-cog me-1"></i> İşlemler</button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item text-success" :href="'/Projeler/Detay/' + p.id"><i class="fas fa-eye me-1"></i> Detay</a></li>
                                        <li><a class="dropdown-item text-primary" :href="'/Projeler/Edit/' + p.id"><i class="fas fa-edit me-1"></i> Güncelle</a></li>
                                        <li v-if="p.silinebilirMi"><a class="dropdown-item text-danger" href="#" @@click.prevent="projeSil(p)"><i class="fas fa-trash me-1"></i> Sil</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                        <tr v-if="projeler.length === 0">
                            <td colspan="6" class="p-0">
                                <div class="projeler-empty">
                                    <div class="empty-icon"><i class="fas fa-folder-open"></i></div>
                                    <div class="empty-title">Henüz proje yok</div>
                                    <p class="small mb-3">İlk projenizi oluşturmak için aşağıdaki butonu kullanın.</p>
                                    <a href="/Projeler/Create" class="btn btn-primary btn-sm text-white"><i class="fas fa-plus me-1"></i> Yeni Proje</a>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
<script>
const { createApp } = Vue;
createApp({
    data() { return { projeler: [] }; },
    mounted() {
        axios.get('/api/Projeler').then(r => { this.projeler = r.data; }).then(() => { if (window.setPageLoading) window.setPageLoading(false); }).catch(() => { if (window.setPageLoading) window.setPageLoading(false); });
    },
    methods: {
        formatDate(d) { if (!d) return '-'; return new Date(d).toLocaleDateString('tr-TR'); },
        formatMoney(v) {
            const n = Number(v || 0);
            if (isNaN(n)) return '₺0';
            return n.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' });
        },
        projeSil(p) {
            if (!confirm('"' + p.ad + '" projesini silmek istediğinize emin misiniz?')) return;
            if (window.setPageLoading) window.setPageLoading(true);
            axios.delete('/api/Projeler/' + p.id).then(() => {
                this.projeler = this.projeler.filter(x => x.id !== p.id);
                if (window.setPageLoading) window.setPageLoading(false);
            }).catch(err => {
                if (window.setPageLoading) window.setPageLoading(false);
                const msg = err.response?.data?.error || err.message || 'Silme işlemi başarısız.';
                alert(msg);
            });
        }
    }
}).mount('#projeler-app');
</script>
}
