@{
    Layout = "_AdminLayout";
}
<div id="proje-create-app" v-cloak>
    <div class="card p-4 mb-4">
        <form @@submit.prevent="kaydet">
            <div class="mb-3">
                <label class="form-label">Proje Adı *</label>
                <input v-model="form.ad" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Açıklama</label>
                <textarea v-model="form.aciklama" class="form-control" rows="2"></textarea>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Başlangıç Tarihi</label>
                    <input v-model="form.baslangicTarihi" type="date" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Planlanan Bitiş Tarihi</label>
                    <input v-model="form.planlananBitisTarihi" type="date" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Sorumlu</label>
                <select v-model="form.sorumluKullaniciId" class="form-select">
                    <option :value="null">Seçiniz</option>
                    <option v-for="k in kullanicilar" :key="k.id" :value="k.id">{{ k.adSoyad }}</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Yetkilendirme</label>
                <div>
                    <label class="me-3"><input type="radio" v-model="form.yetkiTipi" :value="0" /> Genel (tüm kullanıcılar)</label>
                    <label><input type="radio" v-model="form.yetkiTipi" :value="1" /> Kişi bazlı</label>
                </div>
                <div v-if="form.yetkiTipi === 1" class="mt-2">
                    <select v-model="form.yetkiKullaniciIds" multiple class="form-select" style="height:120px">
                        <option v-for="k in kullanicilar" :key="k.id" :value="k.id">{{ k.adSoyad }}</option>
                    </select>
                    <small class="text-muted">Birden fazla seçebilirsiniz.</small>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Adımlar (isteğe bağlı)</label>
                <div v-for="(d, i) in form.detaylar" :key="i" class="d-flex gap-2 mb-2 align-items-start">
                    <input v-model="d.adimAdi" class="form-control" placeholder="Adım adı" />
                    <select v-model="d.kategoriId" class="form-select" style="width:140px">
                        <option :value="null">Kategori</option>
                        <option v-for="k in kategoriler" :key="k.id" :value="k.id">{{ k.ad }}</option>
                    </select>
                    <button type="button" class="btn btn-outline-danger btn-sm" @@click="form.detaylar.splice(i,1)"><i class="fas fa-times"></i></button>
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm" @@click="form.detaylar.push({ adimAdi: '', kategoriId: null, aciklama: '', sira: form.detaylar.length })"><i class="fas fa-plus me-1"></i> Adım Ekle</button>
            </div>
            <hr />
            <button type="submit" class="btn btn-primary">Kaydet</button>
            <a href="/Projeler" class="btn btn-secondary ms-2">İptal</a>
        </form>
    </div>
</div>
@section Scripts {
<script>
const { createApp } = Vue;
createApp({
    data() {
        return {
            kullanicilar: [],
            kategoriler: [],
            form: {
                ad: '',
                aciklama: '',
                baslangicTarihi: null,
                planlananBitisTarihi: null,
                sorumluKullaniciId: null,
                aktifMi: true,
                yetkiTipi: 0,
                yetkiKullaniciIds: [],
                detaylar: []
            }
        };
    },
    mounted() {
        axios.get('/api/Kullanicilar').then(r => { this.kullanicilar = r.data; });
        axios.get('/api/Parametre/kategoriler').then(r => { this.kategoriler = r.data; });
    },
    methods: {
        kaydet() {
            const payload = { ...this.form };
            if (payload.yetkiTipi === 0) payload.yetkiKullaniciIds = null;
            payload.detaylar = this.form.detaylar.map((d, i) => ({ adimAdi: d.adimAdi, kategoriId: d.kategoriId, aciklama: d.aciklama || '', sira: i + 1 }));
            axios.post('/api/Projeler', payload).then(r => { window.location.href = '/Projeler/Detay/' + r.data.id; }).catch(e => alert('Hata: ' + (e.response?.data?.message || e.message)));
        }
    }
}).mount('#proje-create-app');
</script>
}
