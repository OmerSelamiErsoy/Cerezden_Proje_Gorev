@{
    Layout = "_AdminLayout";
}
<style>
    /* Adımlar bölümü */
    .proje-create-adimlar {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 1.25rem;
    }
    .proje-create-adimlar .adimlar-baslik {
        font-size: 0.875rem;
        font-weight: 600;
        color: #475569;
        margin-bottom: 1rem;
    }
    .proje-create-adimlar .adim-satir {
        display: flex;
        gap: 10px;
        align-items: center;
        padding: 10px 12px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        margin-bottom: 8px;
    }
    .proje-create-adimlar .adim-satir .adim-numara {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #e2e8f0;
        color: #64748b;
        font-size: 0.8125rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .proje-create-adimlar .adim-satir .adim-ad-input { flex: 1; min-width: 0; }
    .proje-create-adimlar .adim-satir .adim-kategori { width: 160px; flex-shrink: 0; }
    .proje-create-adimlar .adim-ekle-btn {
        margin-top: 10px;
        border-style: dashed;
        border-width: 2px;
    }
    /* Paylaşılacak Kişiler - görev ekle ile aynı */
    .paylasilacak-kisiler-list {
        max-height: 220px;
        overflow-y: auto;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 8px;
        background: #fafafa;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s ease;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item:hover { background: #f1f5f9; }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item .custom-checkbox-wrap {
        flex-shrink: 0;
        width: 22px;
        height: 22px;
        position: relative;
        border-radius: 6px;
        border: 2px solid #cbd5e1;
        background: #fff;
        transition: border-color 0.2s, background 0.2s;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item.selected .custom-checkbox-wrap {
        background: #3b82f6;
        border-color: #3b82f6;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item .custom-checkbox-wrap .check-icon {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.2s;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item.selected .custom-checkbox-wrap .check-icon { opacity: 1; }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item .custom-checkbox-wrap .check-icon svg {
        width: 14px;
        height: 14px;
        stroke: #fff;
    }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item .kisi-adi { flex: 1; font-weight: 500; color: #1e293b; }
    .paylasilacak-kisiler-list .paylasilacak-kisi-item .kisi-ceptel { font-size: 0.875rem; color: #64748b; }
</style>
<div id="proje-create-app" v-cloak>
    <div class="card p-4 mb-4">
        <form @@submit.prevent="kaydet">
            <div class="mb-3">
                <label class="form-label">Proje Adı *</label>
                <input v-model="form.ad" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Açıklama</label>
                <textarea v-model="form.aciklama" class="form-control" rows="2"></textarea>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Başlangıç Tarihi</label>
                    <input v-model="form.baslangicTarihi" type="date" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Planlanan Bitiş Tarihi</label>
                    <input v-model="form.planlananBitisTarihi" type="date" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Sorumlu</label>
                <select v-model="form.sorumluKullaniciId" class="form-select">
                    <option :value="null">Seçiniz</option>
                    <option v-for="k in kullanicilar" :key="k.id" :value="k.id">{{ k.adSoyad }} - {{ k.cepTel || '-' }}</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Paylaşılacak Kişiler</label>
                <div>
                    <label class="me-3"><input type="radio" v-model="form.yetkiTipi" :value="0" /> Genel (tüm kullanıcılar)</label>
                    <label><input type="radio" v-model="form.yetkiTipi" :value="1" /> Kişi bazlı</label>
                </div>
                <div v-if="form.yetkiTipi === 1" class="mt-2">
                    <div class="paylasilacak-kisiler-list">
                        <div v-for="k in kullanicilar" :key="k.id" class="paylasilacak-kisi-item" :class="{ selected: (form.yetkiKullaniciIds || []).indexOf(k.id) !== -1 }" @@click="yetkiKullaniciToggle(k)">
                            <div class="custom-checkbox-wrap">
                                <span class="check-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
                            </div>
                            <span class="kisi-adi">{{ k.adSoyad }}</span>
                            <span class="kisi-ceptel">{{ k.cepTel || '-' }}</span>
                        </div>
                    </div>
                    <small class="text-muted">Birden fazla kişi seçebilirsiniz.</small>
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label">Adımlar (isteğe bağlı)</label>
                <div class="proje-create-adimlar">
                    <div class="adimlar-baslik"><i class="fas fa-list-ol me-1"></i> Proje adımları</div>
                    <div v-for="(d, i) in form.detaylar" :key="i" class="adim-satir">
                        <span class="adim-numara">{{ i + 1 }}</span>
                        <input v-model="d.adimAdi" class="form-control form-control-sm adim-ad-input" placeholder="Adım adı" />
                        <select v-model="d.kategoriId" class="form-select form-select-sm adim-kategori">
                            <option :value="null">Kategori</option>
                            <option v-for="k in kategoriler" :key="k.id" :value="k.id">{{ k.ad }}</option>
                        </select>
                        <button type="button" class="btn btn-outline-danger btn-sm" @@click="form.detaylar.splice(i,1)" title="Adımı sil"><i class="fas fa-times"></i></button>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm adim-ekle-btn" @@click="form.detaylar.push({ adimAdi: '', kategoriId: null, aciklama: '', sira: form.detaylar.length })"><i class="fas fa-plus me-1"></i> Adım Ekle</button>
                </div>
            </div>
            <hr />
            <button type="submit" class="btn btn-primary">Kaydet</button>
            <a href="/Projeler" class="btn btn-secondary ms-2">İptal</a>
        </form>
    </div>
</div>
@section Scripts {
<script>
const { createApp } = Vue;
createApp({
    data() {
        return {
            kullanicilar: [],
            kategoriler: [],
            form: {
                ad: '',
                aciklama: '',
                baslangicTarihi: null,
                planlananBitisTarihi: null,
                sorumluKullaniciId: null,
                aktifMi: true,
                yetkiTipi: 0,
                yetkiKullaniciIds: [],
                detaylar: []
            }
        };
    },
    mounted() {
        axios.get('/api/Kullanicilar').then(r => { this.kullanicilar = r.data; });
        axios.get('/api/Parametre/kategoriler').then(r => { this.kategoriler = r.data; });
    },
    methods: {
        yetkiKullaniciToggle(k) {
            const ids = this.form.yetkiKullaniciIds || [];
            const idx = ids.indexOf(k.id);
            if (idx === -1) ids.push(k.id);
            else ids.splice(idx, 1);
            this.form.yetkiKullaniciIds = ids;
        },
        kaydet() {
            const payload = { ...this.form };
            if (payload.yetkiTipi === 0) payload.yetkiKullaniciIds = null;
            payload.detaylar = this.form.detaylar.map((d, i) => ({ adimAdi: d.adimAdi, kategoriId: d.kategoriId, aciklama: d.aciklama || '', sira: i + 1 }));
            axios.post('/api/Projeler', payload).then(r => { window.location.href = '/Projeler/Detay/' + r.data.id; }).catch(e => alert('Hata: ' + (e.response?.data?.message || e.message)));
        }
    }
}).mount('#proje-create-app');
</script>
}
