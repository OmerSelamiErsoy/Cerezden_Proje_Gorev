@section Scripts {
<script>
const { createApp } = Vue;
const denetimId = Number(document.getElementById('sd-detay').dataset.denetimId || 0);

createApp({
    data() {
        return {
            loading: true,
            saving: false,
            denetim: { id: denetimId, ad: '', kayitTarihi: null, olusturanAdSoyad: '', canDelete: false, yetkiTipi: 1, yetkiKullaniciIds: [], kapaliMi: false, kapatanAdSoyad: '', kapatmaTarihi: null, geriAcanAdSoyad: '', geriAcmaTarihi: null, lokasyonId: null, lokasyonAdi: '', adimlar: [] },
            kategoriler: [],
            lokasyonlar: [],
            kullanicilar: [],
            adimForm: { id: null, ad: '', aciklama: '', kategoriId: null, tipler: 0, sira: 1 },
            adimTipSecim: { puanlama: false, ilgiliKisiler: false, ilgiliUrunler: false },
            kisiModal: { adimId: null, idx: null, adSoyad: '', aciklama: '' },
            urunModal: { adimId: null, idx: null, stokKodu: '', stokAdi: '', adet: 0, aciklama: '' },
            denetimGuncelleForm: { ad: '', lokasyonMagazaKodu: '', yetkiTipi: 1, yetkiKullaniciIds: [] },
            klonlaForm: { ad: '' }
        };
    },
    computed: {
        gruplanmis() {
            const map = new Map();
            (this.denetim.adimlar || []).forEach(a => {
                const key = a.kategoriId ? String(a.kategoriId) : 'none';
                const kategoriAd = a.kategoriAd || 'Kategorisiz';
                if (!map.has(key)) map.set(key, { kategoriKey: key, kategoriAd, adimlar: [] });
                map.get(key).adimlar.push(a);
            });
            return Array.from(map.values());
        },
        paylasilanKisiler() {
            const ids = (this.denetim && Array.isArray(this.denetim.yetkiKullaniciIds))
                ? this.denetim.yetkiKullaniciIds
                : [];
            if (!ids || ids.length === 0) return [];
            const list = (this.kullanicilar || []).filter(k => ids.indexOf(k.id) !== -1);
            return list.sort((a, b) => (a.adSoyad || '').localeCompare(b.adSoyad || '', 'tr'));
        }
    },
    mounted() {
        Promise.all([
            axios.get('/api/saha-denetim/' + denetimId).then(r => { this.denetim = r.data; this.denetim.adimlar = this.denetim.adimlar || []; }),
            axios.get('/api/Parametre/saha-denetim-kategorileri').then(r => { this.kategoriler = (r.data || []).slice().sort((a,b) => (a.ad||'').localeCompare(b.ad||'', 'tr')); }),
            axios.get('/api/saha-denetim/lokasyonlar').then(r => { this.lokasyonlar = r.data || []; }),
            axios.get('/api/Kullanicilar').then(r => { this.kullanicilar = r.data || []; })
        ])
        .finally(() => { this.loading = false; if (window.setPageLoading) window.setPageLoading(false); });
    },
    methods: {
        formatDate(v) { if (!v) return '-'; try { const d = new Date(v); return isNaN(d.getTime()) ? '-' : d.toLocaleDateString('tr-TR'); } catch { return '-'; } },
        formatDateTime(v) { if (!v) return '-'; try { const d = new Date(v); return isNaN(d.getTime()) ? '-' : d.toLocaleString('tr-TR'); } catch { return '-'; } },
        yetkiKullaniciToggle(k) {
            const ids = this.denetimGuncelleForm.yetkiKullaniciIds || [];
            const idx = ids.indexOf(k.id);
            if (idx === -1) ids.push(k.id);
            else ids.splice(idx, 1);
            this.denetimGuncelleForm.yetkiKullaniciIds = ids;
        },
            paylasimKisileriAc() {
                if (Number(this.denetim?.yetkiTipi ?? 1) !== 1) return;
                const el = document.getElementById('sdPaylasimModal');
                if (!el) return;
                new bootstrap.Modal(el).show();
            },
        hasTip(a, flag) { return ((Number(a.tipler || 0)) & flag) === flag; },
        calcTipler() {
            let t = 0;
            if (this.adimTipSecim.puanlama) t |= 1;
            if (this.adimTipSecim.ilgiliKisiler) t |= 2;
            if (this.adimTipSecim.ilgiliUrunler) t |= 4;
            return t;
        },
        tipSecimFrom(tipler) {
            const t = Number(tipler || 0);
            this.adimTipSecim = { puanlama: (t & 1) === 1, ilgiliKisiler: (t & 2) === 2, ilgiliUrunler: (t & 4) === 4 };
        },

        adimEkleAc() {
            if (this.denetim.kapaliMi) return;
            this.adimForm = { id: null, ad: '', aciklama: '', kategoriId: null, tipler: 0, sira: 0 };
            this.adimTipSecim = { puanlama: false, ilgiliKisiler: false, ilgiliUrunler: false };
            new bootstrap.Modal(document.getElementById('sdAdimModal')).show();
        },
        adimDuzenleAc(a) {
            if (this.denetim.kapaliMi) return;
            this.adimForm = { id: a.id, ad: a.ad, aciklama: a.aciklama || '', kategoriId: a.kategoriId || null, tipler: Number(a.tipler || 0), sira: a.sira || 1 };
            this.tipSecimFrom(this.adimForm.tipler);
            bootstrap.Modal.getInstance(document.getElementById('sdAdimListeModal'))?.hide();
            new bootstrap.Modal(document.getElementById('sdAdimModal')).show();
        },
        adimKaydet() {
            if (!this.adimForm.ad || !this.adimForm.ad.trim()) { alert('Adım adı zorunludur.'); return; }
            this.saving = true;
            const payload = {
                ad: this.adimForm.ad.trim(),
                aciklama: this.adimForm.aciklama || null,
                kategoriId: this.adimForm.kategoriId,
                tipler: this.calcTipler(),
                sira: this.adimForm.sira || 1
            };
            const p = this.adimForm.id
                ? axios.put('/api/saha-denetim/adim/' + this.adimForm.id, payload)
                : axios.post('/api/saha-denetim/' + denetimId + '/adim', payload);
            p.then(() => axios.get('/api/saha-denetim/' + denetimId))
                .then(r => { this.denetim = r.data; this.denetim.adimlar = this.denetim.adimlar || []; bootstrap.Modal.getInstance(document.getElementById('sdAdimModal')).hide(); })
                .catch(e => alert(e.response?.data?.message || 'Kaydedilemedi.'))
                .finally(() => { this.saving = false; });
        },
        adimListeAc() { new bootstrap.Modal(document.getElementById('sdAdimListeModal')).show(); },
        adimSil(a) {
            if (this.denetim.kapaliMi) return;
            if (!confirm('Silmek istediğinize emin misiniz?')) return;
            this.saving = true;
            axios.delete('/api/saha-denetim/adim/' + a.id)
                .then(() => axios.get('/api/saha-denetim/' + denetimId))
                .then(r => { this.denetim = r.data; this.denetim.adimlar = this.denetim.adimlar || []; })
                .catch(e => alert(e.response?.data?.message || 'Silinemedi.'))
                .finally(() => { this.saving = false; });
        },
        denetimSil() {
            if (this.denetim.kapaliMi) return;
            if (!this.denetim.canDelete) { alert('Bu denetimi silme yetkiniz yok.'); return; }
            if (!confirm('Denetimi silmek istediğinize emin misiniz?')) return;
            this.saving = true;
            axios.delete('/api/saha-denetim/' + denetimId)
                .then(() => { window.location.href = '/SahaDenetim'; })
                .catch(e => alert(e.response?.data?.message || 'Silinemedi.'))
                .finally(() => { this.saving = false; });
        },
        denetimGuncelleAc() {
            if (this.denetim.kapaliMi) return;
            this.denetimGuncelleForm = {
                ad: this.denetim.ad || '',
                lokasyonMagazaKodu: (this.denetim.lokasyonId != null ? String(this.denetim.lokasyonId) : ''),
                yetkiTipi: Number(this.denetim.yetkiTipi ?? 1),
                yetkiKullaniciIds: (this.denetim.yetkiKullaniciIds || []).slice()
            };
            new bootstrap.Modal(document.getElementById('sdDenetimGuncelleModal')).show();
        },
        denetimGuncelleKaydet() {
            if (this.denetim.kapaliMi) return;
            if (!this.denetimGuncelleForm.ad || !this.denetimGuncelleForm.ad.trim()) { alert('Denetim adı zorunludur.'); return; }
            if (!confirm('Güncellemek istediğinize emin misiniz?')) return;
            this.saving = true;
            axios.put('/api/saha-denetim/' + denetimId, {
                ad: this.denetimGuncelleForm.ad.trim(),
                lokasyonMagazaKodu: (this.denetimGuncelleForm.lokasyonMagazaKodu || null),
                kayitTarihi: null,
                yetkiTipi: this.denetimGuncelleForm.yetkiTipi,
                yetkiKullaniciIds: this.denetimGuncelleForm.yetkiTipi === 1 ? (this.denetimGuncelleForm.yetkiKullaniciIds || []) : null
            })
                .then(() => axios.get('/api/saha-denetim/' + denetimId))
                .then(r => { this.denetim = r.data; this.denetim.adimlar = this.denetim.adimlar || []; bootstrap.Modal.getInstance(document.getElementById('sdDenetimGuncelleModal'))?.hide(); })
                .catch(e => alert(e.response?.data?.message || 'Güncellenemedi.'))
                .finally(() => { this.saving = false; });
        },
        logModalAc() {
            new bootstrap.Modal(document.getElementById('sdLogModal')).show();
        },
        toggleKapat() {
            const hedefKapali = !this.denetim.kapaliMi;
            const msg = hedefKapali ? 'Denetimi kapatmak istediğinize emin misiniz?' : 'Denetimi geri açmak istediğinize emin misiniz?';
            if (!confirm(msg)) return;
            this.saving = true;
            const p = hedefKapali ? axios.post('/api/saha-denetim/' + denetimId + '/kapat') : axios.post('/api/saha-denetim/' + denetimId + '/geri-ac');
            p.then(() => axios.get('/api/saha-denetim/' + denetimId))
                .then(r => { this.denetim = r.data; this.denetim.adimlar = this.denetim.adimlar || []; })
                .catch(e => alert(e.response?.data?.message || 'İşlem başarısız.'))
                .finally(() => { this.saving = false; });
        },
        klonla() {
            this.klonlaForm = { ad: (this.denetim.ad ? (this.denetim.ad + ' (Kopya)') : 'Kopya Denetim') };
            new bootstrap.Modal(document.getElementById('sdKlonlaModal')).show();
        },
        klonlaOnayla() {
            const ad = (this.klonlaForm.ad || '').trim();
            if (!ad) { alert('Yeni denetim adı zorunludur.'); return; }
            if (!confirm('Bu denetimin adımlarını yeni denetime kopyalamak istediğinize emin misiniz?')) return;
            this.saving = true;
            axios.post('/api/saha-denetim/' + denetimId + '/klonla', { ad })
                .then(r => {
                    bootstrap.Modal.getInstance(document.getElementById('sdKlonlaModal'))?.hide();
                    window.location.href = '/SahaDenetim/Detay/' + r.data.id;
                })
                .catch(e => alert(e.response?.data?.message || 'Klonlanamadı.'))
                .finally(() => { this.saving = false; });
        },

        fotoSec(a) {
            if (this.denetim.kapaliMi) return;
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'image/*';
            input.multiple = true;
            input.onchange = () => {
                const files = Array.from(input.files || []);
                if (files.length === 0) return;
                const fd = new FormData();
                files.forEach(x => fd.append('files', x));
                this.saving = true;
                axios.post('/api/saha-denetim/adim/' + a.id + '/foto', fd, { headers: { 'Content-Type': 'multipart/form-data' } })
                    .then(() => axios.get('/api/saha-denetim/' + denetimId))
                    .then(r => { this.denetim = r.data; this.denetim.adimlar = this.denetim.adimlar || []; })
                    .catch(e => alert(e.response?.data?.message || 'Fotoğraf yüklenemedi.'))
                    .finally(() => { this.saving = false; });
            };
            input.click();
        },
        fotoSil(a, f) {
            if (this.denetim.kapaliMi) return;
            if (!confirm('Fotoğrafı silmek istediğinize emin misiniz?')) return;
            this.saving = true;
            axios.delete('/api/saha-denetim/adim/foto/' + f.id)
                .then(() => axios.get('/api/saha-denetim/' + denetimId))
                .then(r => { this.denetim = r.data; this.denetim.adimlar = this.denetim.adimlar || []; })
                .catch(e => alert(e.response?.data?.message || 'Fotoğraf silinemedi.'))
                .finally(() => { this.saving = false; });
        },

        setPuan(a, p) {
            a.puan = p;
            this.adimDoldurKaydet(a);
        },
        kisiModalAc(a, kisi, idx) {
            if (this.denetim.kapaliMi) return;
            this.kisiModal = {
                adimId: a.id,
                idx: (typeof idx === 'number') ? idx : null,
                adSoyad: kisi ? (kisi.adSoyad || '') : '',
                aciklama: kisi ? (kisi.aciklama || '') : ''
            };
            new bootstrap.Modal(document.getElementById('sdKisiModal')).show();
        },
        kisiModalKaydet() {
            const a = (this.denetim.adimlar || []).find(x => x.id === this.kisiModal.adimId);
            if (!a) return;
            if (!this.kisiModal.adSoyad || !this.kisiModal.adSoyad.trim()) { alert('Kişi Adı-Soyadı zorunludur.'); return; }
            a.ilgiliKisiler = (a.ilgiliKisiler || []);
            const item = { adSoyad: this.kisiModal.adSoyad.trim(), aciklama: (this.kisiModal.aciklama || '').trim() || null };
            if (this.kisiModal.idx === null) a.ilgiliKisiler.push(item);
            else a.ilgiliKisiler.splice(this.kisiModal.idx, 1, item);
            bootstrap.Modal.getInstance(document.getElementById('sdKisiModal')).hide();
            this.adimDoldurKaydet(a);
        },
        kisiSil(a, idx) {
            if (this.denetim.kapaliMi) return;
            if (!confirm('Silmek istediğinize emin misiniz?')) return;
            (a.ilgiliKisiler || []).splice(idx, 1);
            this.adimDoldurKaydet(a);
        },
        urunModalAc(a, urun, idx) {
            if (this.denetim.kapaliMi) return;
            this.urunModal = {
                adimId: a.id,
                idx: (typeof idx === 'number') ? idx : null,
                stokKodu: urun ? (urun.stokKodu || '') : '',
                stokAdi: urun ? (urun.stokAdi || '') : '',
                adet: urun ? Number(urun.adet || 0) : 0,
                aciklama: urun ? (urun.aciklama || '') : ''
            };
            new bootstrap.Modal(document.getElementById('sdUrunModal')).show();
        },
        urunModalKaydet() {
            const a = (this.denetim.adimlar || []).find(x => x.id === this.urunModal.adimId);
            if (!a) return;
            if (!this.urunModal.stokKodu || !this.urunModal.stokKodu.trim()) { alert('Stok Kodu zorunludur.'); return; }
            const adet = Number(this.urunModal.adet || 0);
            a.ilgiliUrunler = (a.ilgiliUrunler || []);
            const item = {
                stokKodu: this.urunModal.stokKodu.trim(),
                stokAdi: (this.urunModal.stokAdi || '').trim() || null,
                adet: isNaN(adet) ? 0 : adet,
                aciklama: (this.urunModal.aciklama || '').trim() || null
            };
            if (this.urunModal.idx === null) a.ilgiliUrunler.push(item);
            else a.ilgiliUrunler.splice(this.urunModal.idx, 1, item);
            bootstrap.Modal.getInstance(document.getElementById('sdUrunModal')).hide();
            this.adimDoldurKaydet(a);
        },
        urunSil(a, idx) {
            if (this.denetim.kapaliMi) return;
            if (!confirm('Silmek istediğinize emin misiniz?')) return;
            (a.ilgiliUrunler || []).splice(idx, 1);
            this.adimDoldurKaydet(a);
        },
        adimDoldurKaydet(a) {
            if (this.denetim.kapaliMi) return;
            const payload = {
                yapildiMi: !!a.yapildiMi,
                puan: a.puan ?? null,
                personelYorum: a.personelYorum || null,
                not: a.not || null,
                ilgiliKisiler: (a.ilgiliKisiler || []).map(x => ({ adSoyad: x.adSoyad, aciklama: x.aciklama || null })),
                ilgiliUrunler: (a.ilgiliUrunler || []).map(x => ({ stokKodu: x.stokKodu, stokAdi: x.stokAdi || null, adet: x.adet, aciklama: x.aciklama || null }))
            };
            axios.put('/api/saha-denetim/adim/' + a.id + '/doldur', payload).catch(() => {});
        }
    }
}).mount('#sd-detay');
</script>
}

