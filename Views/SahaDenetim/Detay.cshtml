@{
    Layout = "_AdminLayout";
    var denetimId = ViewData["DenetimId"] as int? ?? 0;
}

@section Head {
    <style>
        #sd-detay .adim-accordion .accordion-item { border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; background: #fff; }
        #sd-detay .adim-accordion .accordion-item.adim-yapildi { background: #dfffe1; border-color: #bfe9c3; }
        #sd-detay .adim-accordion .accordion-item.adim-yapildi .accordion-button { background: #dfffe1; }
        #sd-detay .adim-accordion .accordion-item.adim-yapildi .accordion-button:not(.collapsed) { background: #dfffe1; }
        #sd-detay .adim-accordion .accordion-header { margin: 0; }
        #sd-detay .adim-accordion .accordion-button { padding: 14px; }
        #sd-detay .adim-accordion .accordion-button:not(.collapsed) { background: #fff; box-shadow: none; }
        #sd-detay .adim-accordion .accordion-button:focus { box-shadow: none; }
        #sd-detay .adim-accordion .accordion-body { padding: 14px; padding-top: 0; }
        #sd-detay .adim-accordion .accordion-button::after { margin-left: 12px; }
        #sd-detay .kategori-baslik { font-weight: 700; color: #0f172a; }
        #sd-detay .adim-baslik { font-weight: 600; }
        #sd-detay .adim-aciklama { color: #64748b; }
        #sd-detay .star { cursor: pointer; color: #cbd5e1; }
        #sd-detay .star.active { color: #f59e0b; }
        #sd-detay textarea { resize: vertical; }

        #sd-detay .badge-soft {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 999px;
            font-weight: 700;
            font-size: 0.78rem;
            border: 1px solid transparent;
        }
        #sd-detay .badge-soft.private { background:#eef2ff; color:#3730a3; border-color:#e0e7ff; }
        #sd-detay .badge-soft.shared { background:#ecfeff; color:#155e75; border-color:#cffafe; }
        #sd-detay .sd-share-badge { cursor: pointer; user-select: none; }
        #sd-detay .sd-share-badge:hover { filter: brightness(0.98); }

        /* Paylaşılacak Kişiler (Denetim Güncelle Modal) */
        #sd-detay .paylasilacak-kisiler-list {
            max-height: 260px;
            overflow-y: auto;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 8px;
            background: #fafafa;
        }
        #sd-detay .paylasilacak-kisiler-list .paylasilacak-kisi-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.15s ease;
        }
        #sd-detay .paylasilacak-kisiler-list .paylasilacak-kisi-item:hover { background: #f1f5f9; }
        #sd-detay .paylasilacak-kisiler-list .paylasilacak-kisi-item .custom-checkbox-wrap {
            flex-shrink: 0;
            width: 22px;
            height: 22px;
            position: relative;
            border-radius: 6px;
            border: 2px solid #cbd5e1;
            background: #fff;
            transition: border-color 0.2s, background 0.2s;
        }
        #sd-detay .paylasilacak-kisiler-list .paylasilacak-kisi-item.selected .custom-checkbox-wrap {
            background: #3b82f6;
            border-color: #3b82f6;
        }
        #sd-detay .paylasilacak-kisiler-list .paylasilacak-kisi-item .custom-checkbox-wrap .check-icon {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.2s;
        }
        #sd-detay .paylasilacak-kisiler-list .paylasilacak-kisi-item.selected .custom-checkbox-wrap .check-icon { opacity: 1; }
        #sd-detay .paylasilacak-kisiler-list .paylasilacak-kisi-item .custom-checkbox-wrap .check-icon svg {
            width: 14px;
            height: 14px;
            stroke: #fff;
        }
        #sd-detay .paylasilacak-kisiler-list .paylasilacak-kisi-item .kisi-adi { flex: 1; font-weight: 500; color: #1e293b; }
        #sd-detay .paylasilacak-kisiler-list .paylasilacak-kisi-item .kisi-ceptel { font-size: 0.875rem; color: #64748b; }

        /* Modern detay görünümü */
        #sd-detay .step-meta-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 8px;
            margin-top: 6px;
        }
        #sd-detay .chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 0.8rem;
            border: 1px solid #e2e8f0;
            color: #0f172a;
            background: #fff;
        }
        #sd-detay .chip-muted { color: #64748b; background: #f8fafc; }
        #sd-detay .chip-tip { background: #eff6ff; border-color: #bfdbfe; color: #1d4ed8; }
        #sd-detay .section {
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px dashed #e2e8f0;
        }
        #sd-detay .section:first-child { border-top: 0; padding-top: 0; margin-top: 0; }
        #sd-detay .section-title {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 10px;
        }
        #sd-detay .section-title .left {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            color: #0f172a;
        }
        #sd-detay .section-box {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 12px;
        }
        #sd-detay .inline-actions .btn { padding: 0.15rem 0.45rem; }
        #sd-detay .hint {
            font-size: 0.8rem;
            color: #64748b;
        }
        #sd-detay .rating-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        #sd-detay .rating-value {
            font-size: 0.85rem;
            color: #64748b;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 999px;
            padding: 4px 10px;
        }
        #sd-detay .kv {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        #sd-detay .kv label { margin: 0; font-size: 0.8rem; color: #64748b; }

        /* Yapıldı switch (daha modern) */
        #sd-detay .done-switch {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            border: 1px solid #e2e8f0;
            border-radius: 999px;
            background: #f8fafc;
        }
        #sd-detay .done-switch .form-check-input {
            width: 2.65rem;
            height: 1.4rem;
            /* Bootstrap .form-switch negatif margin veriyor; kartlarda kesilmesin */
            margin-left: 0 !important;
            margin-top: 0;
            cursor: pointer;
            border: 1px solid #cbd5e1;
            background-color: #e2e8f0;
        }
        #sd-detay .done-switch .form-check-input:focus {
            box-shadow: 0 0 0 0.2rem rgba(59, 130, 246, 0.16);
            border-color: #93c5fd;
        }
        #sd-detay .done-switch .form-check-input:checked {
            background-color: #22c55e;
            border-color: #22c55e;
        }
        #sd-detay .done-switch .done-label {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 800;
            color: #0f172a;
            cursor: pointer;
            user-select: none;
        }
        #sd-detay .done-switch .done-state {
            font-size: 0.78rem;
            font-weight: 800;
            padding: 3px 10px;
            border-radius: 999px;
            border: 1px solid #e2e8f0;
            background: #fff;
            color: #64748b;
        }
        #sd-detay .done-switch .done-state.on {
            background: #dfffe1;
            border-color: #bfe9c3;
            color: #166534;
        }

        /* Fotoğraflar */
        #sd-detay .photo-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 10px;
        }
        #sd-detay .photo-item {
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
            background: #fff;
        }
        #sd-detay .photo-item img {
            width: 100%;
            height: 110px;
            object-fit: cover;
            display: block;
        }
        #sd-detay .photo-item .photo-meta {
            padding: 8px 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
        }
        #sd-detay .photo-item .photo-name {
            font-size: 0.78rem;
            color: #64748b;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* Accordion daha modern ve anlaşılır */
        #sd-detay .adim-accordion .accordion-item {
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 1px 0 rgba(15, 23, 42, 0.02);
            transition: box-shadow 0.15s ease, transform 0.15s ease;
        }
        #sd-detay .adim-accordion .accordion-item:hover {
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
            transform: translateY(-1px);
        }
        #sd-detay .adim-accordion .accordion-button {
            padding: 14px 16px;
            background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        }
        #sd-detay .adim-accordion .accordion-button:not(.collapsed) {
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
        }
        #sd-detay .sd-step-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 14px;
            width: 100%;
        }
        #sd-detay .sd-step-left { flex: 1; min-width: 240px; }
        #sd-detay .sd-step-title-row {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        #sd-detay .sd-step-status-dot {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            background: #ef4444; /* açık */
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.12);
            margin-top: 2px;
        }
        #sd-detay .sd-step-status-dot.done {
            background: #22c55e;
            box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.14);
        }
        #sd-detay .sd-step-title {
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.01em;
        }
        #sd-detay .sd-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            border: 1px solid #e2e8f0;
            background: #fff;
            color: #0f172a;
            white-space: nowrap;
        }
        #sd-detay .sd-pill.muted { color: #64748b; background: #f8fafc; }
        #sd-detay .sd-pill.done { color: #166534; border-color: #bfe9c3; background: #dfffe1; }
        #sd-detay .sd-pill.score { color: #92400e; border-color: #fde68a; background: #fffbeb; }
        #sd-detay .sd-step-desc {
            margin-top: 6px;
            color: #64748b;
            font-size: 0.9rem;
        }
        #sd-detay .sd-step-right {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }
        #sd-detay .sd-step-right .sd-pill { background: #f8fafc; }

        /* İlgili Ürünler - modern görünüm */
        #sd-detay .urun-list { display: flex; flex-direction: column; gap: 10px; }
        #sd-detay .urun-item {
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 12px 12px;
            background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
            box-shadow: 0 1px 0 rgba(15, 23, 42, 0.02);
            transition: box-shadow 0.15s ease, transform 0.15s ease;
        }
        #sd-detay .urun-item:hover { box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08); transform: translateY(-1px); }
        #sd-detay .urun-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
        #sd-detay .urun-left { flex: 1; min-width: 0; }
        #sd-detay .urun-code-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        #sd-detay .urun-code { font-weight: 900; color: #0f172a; letter-spacing: -0.01em; }
        #sd-detay .urun-name { color: #475569; font-weight: 600; }
        #sd-detay .urun-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-top: 6px; }
        #sd-detay .urun-desc { margin-top: 6px; color: #64748b; line-height: 1.25rem; }
        #sd-detay .urun-actions { display: inline-flex; align-items: center; gap: 6px; flex-shrink: 0; }
        #sd-detay .icon-btn {
            border-radius: 999px;
            padding: 0.28rem 0.55rem;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        #sd-detay .icon-btn i { width: 14px; text-align: center; }

        /* İlgili Kişiler - modern görünüm */
        #sd-detay .kisi-list { display: flex; flex-direction: column; gap: 10px; }
        #sd-detay .kisi-item {
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 12px 12px;
            background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
            box-shadow: 0 1px 0 rgba(15, 23, 42, 0.02);
            transition: box-shadow 0.15s ease, transform 0.15s ease;
        }
        #sd-detay .kisi-item:hover { box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08); transform: translateY(-1px); }
        #sd-detay .kisi-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
        #sd-detay .kisi-left { flex: 1; min-width: 0; }
        #sd-detay .kisi-name-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        #sd-detay .kisi-name { font-weight: 900; color: #0f172a; letter-spacing: -0.01em; }
        #sd-detay .kisi-desc { margin-top: 6px; color: #64748b; line-height: 1.25rem; }
        #sd-detay .kisi-actions { display: inline-flex; align-items: center; gap: 6px; flex-shrink: 0; }
    </style>
}

<div id="sd-detay" data-vue-page data-denetim-id="@denetimId" v-cloak>
    <div class="v-cloak-loading d-flex align-items-center justify-content-center py-5">
        <div class="w-100 text-center">
            <div class="small text-muted mb-2">Yükleniyor...</div>
            <div class="progress" style="max-width:260px;margin:0 auto;">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:100%"></div>
            </div>
        </div>
    </div>

    <div class="v-cloak-hidden">
        <div class="card p-4 mb-3">
            <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                <div>
                    <h4 class="mb-1">{{ denetim.ad || 'Denetim' }}</h4>
                    <div class="small text-muted">
                        <i class="fas fa-user me-1"></i> {{ denetim.olusturanAdSoyad || '-' }}
                        <span class="mx-2">•</span>
                        <i class="fas fa-calendar-alt me-1"></i> {{ formatDate(denetim.kayitTarihi) }}
                        <span class="mx-2">•</span>
                        <i class="fas fa-location-dot me-1"></i> {{ (denetim.lokasyonAdi ? (denetim.lokasyonAdi + ' - ' + (denetim.lokasyonId || '')) : '-') }}
                        <span class="mx-2">•</span>
                        <i class="fas fa-list-ol me-1"></i> Adım Sayısı: {{ (denetim.adimlar || []).length }}
                        <span class="mx-2">•</span>
                        <span v-if="denetim.yetkiTipi === 0" class="badge-soft shared">Genel Paylaşım</span>
                        <span v-else class="badge-soft private sd-share-badge" @@click="paylasimKisileriAc">Kişi bazlı Paylaşım</span>
                    </div>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <a href="/SahaDenetim" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="fas fa-arrow-left me-1"></i> Denetimler</a>

                    <button class="btn btn-outline-secondary btn-sm rounded-pill" type="button" @@click="logModalAc">
                        <i class="fas fa-clipboard-list me-1"></i> Log
                    </button>

                    <button class="btn btn-outline-warning btn-sm rounded-pill" @@click="toggleKapat" :disabled="saving">
                        <i class="fas" :class="denetim.kapaliMi ? 'fa-lock-open' : 'fa-lock'"></i>
                        <span class="ms-1">{{ denetim.kapaliMi ? 'Denetimi Aç' : 'Denetimi Kapat' }}</span>
                    </button>

                    <div class="dropdown" v-if="!denetim.kapaliMi">
                        <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-gear me-1"></i> Ayarlar
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#" @@click.prevent="adimEkleAc()"><i class="fas fa-plus me-2"></i> Adım Ekle</a></li>
                            <li><a class="dropdown-item" href="#" @@click.prevent="adimListeAc()"><i class="fas fa-pen-to-square me-2"></i> Adım Güncelle-Sil</a></li>
                            <li><a class="dropdown-item" href="#" @@click.prevent="denetimGuncelleAc()"><i class="fas fa-pen me-2"></i> Denetimi Güncelle</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="#" @@click.prevent="denetimSil()"><i class="fas fa-trash me-2"></i> Denetimi Sil</a></li>
                        </ul>
                    </div>

                    <button class="btn btn-outline-success btn-sm rounded-pill" type="button" @@click="klonla" :disabled="saving">
                        <i class="fas fa-clone me-1"></i> Klonla
                    </button>
                </div>
            </div>
        </div>

        <div id="sdAdimAccordionRoot">
        <div v-for="grp in gruplanmis" :key="grp.kategoriKey" class="mb-3">
            <div class="mb-2 kategori-baslik">
                <i class="fas fa-folder-tree me-2 text-muted"></i>{{ grp.kategoriAd }}
            </div>
            <div class="d-flex flex-column gap-2">
                <div v-for="a in grp.adimlar" :key="a.id" class="adim-accordion accordion">
                    <div class="accordion-item" :class="{ 'adim-yapildi': !!a.yapildiMi }">
                        <h2 class="accordion-header" :id="'sd-adim-h-' + a.id">
                            <button class="accordion-button collapsed" type="button"
                                    data-bs-toggle="collapse"
                                    :data-bs-target="'#sd-adim-c-' + a.id"
                                    aria-expanded="false"
                                    :aria-controls="'sd-adim-c-' + a.id">
                                <div class="sd-step-head">
                                    <div class="sd-step-left">
                                        <div class="sd-step-title-row">
                                            <span class="sd-step-status-dot" :class="{ done: !!a.yapildiMi }"></span>
                                            <span class="sd-step-title">{{ a.ad }}</span>
                                            <span v-if="!!a.yapildiMi" class="sd-pill done"><i class="fas fa-check"></i> Yapıldı</span>
                                            <span v-else class="sd-pill muted"><i class="fas fa-circle"></i> Açık</span>
                                            <span class="sd-pill muted"><i class="fas fa-tag"></i> {{ a.kategoriAd || 'Kategorisiz' }}</span>
                                        </div>

                                        <div v-if="a.aciklama" class="sd-step-desc">{{ a.aciklama }}</div>
                                    </div>

                                    <div class="sd-step-right">
                                        <span v-if="hasTip(a, 1)" class="sd-pill score"><i class="fas fa-star"></i> {{ a.puan || 0 }}/10</span>
                                        <span v-if="hasTip(a, 2)" class="sd-pill"><i class="fas fa-users"></i> {{ (a.ilgiliKisiler || []).length }}</span>
                                        <span v-if="hasTip(a, 4)" class="sd-pill"><i class="fas fa-box"></i> {{ (a.ilgiliUrunler || []).length }}</span>
                                        <span class="sd-pill"><i class="fas fa-images"></i> {{ (a.fotograflar || []).length }}</span>
                                    </div>
                                </div>
                            </button>
                        </h2>
                        <div :id="'sd-adim-c-' + a.id" class="accordion-collapse collapse" :aria-labelledby="'sd-adim-h-' + a.id" data-bs-parent="#sdAdimAccordionRoot">
                            <div class="accordion-body">
                                <div class="d-flex justify-content-start align-items-center my-2">
                                    <div v-if="!denetim.kapaliMi" class="form-check form-switch done-switch ms-0" style="padding-left:0" @@click.stop>
                                        <input class="form-check-input" type="checkbox" role="switch" v-model="a.yapildiMi" @@change="adimDoldurKaydet(a)" :id="'chk'+a.id">
                                        <label class="done-label" :for="'chk'+a.id">
                                            Yapıldı
                                            <span class="done-state" :class="{ on: !!a.yapildiMi }">{{ a.yapildiMi ? 'Tamam' : 'Bekliyor' }}</span>
                                        </label>
                                    </div>
                                </div>

                                <!-- Puanlama -->
                                <div v-if="hasTip(a, 1)" class="section">
                                    <div class="section-title">
                                        <div class="left"><i class="fas fa-star text-warning"></i> Puanlama</div>
                                        <div class="hint">1-10 arası</div>
                                    </div>
                                    <div class="section-box">
                                        <div class="rating-wrap">
                                            <div>
                                                <i v-for="i in 10" :key="i" class="fas fa-star star me-1" :class="{ active: (a.puan || 0) >= i }" @@click="setPuan(a, i)"></i>
                                            </div>
                                            <div class="rating-value">{{ a.puan || 0 }}/10</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- İlgili Kişiler -->
                                <div v-if="hasTip(a, 2)" class="section">
                                    <div class="section-title">
                                        <div class="left"><i class="fas fa-users text-primary"></i> İlgili Kişiler</div>
                                        <div class="inline-actions">
                                            <button v-if="!denetim.kapaliMi" class="btn btn-sm btn-outline-secondary" @@click="kisiModalAc(a)"><i class="fas fa-user-plus me-1"></i> Ekle</button>
